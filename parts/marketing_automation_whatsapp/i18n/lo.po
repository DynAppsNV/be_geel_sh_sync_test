"<i data-trigger-type=\"whatsapp_read\" class=\"fa fa-check-circle "
"o_ma_text_read o_add_child_activity text-info\" title=\"Opened\" "
"role=\"img\" aria-label=\"Opened\"/>\n"
"                <i data-trigger-type=\"whatsapp_not_read\" class=\"fa fa-"
"check-circle o_ma_text_read o_add_child_activity text-danger\" title=\"Not "
