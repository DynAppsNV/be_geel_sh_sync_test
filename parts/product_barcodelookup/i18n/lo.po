msgstr ""
"ພົບຮູບພາບທີ່ກົງກັນ %(matching_images_count)s ຮູບ ສຳລັບສິນຄ້າ %(product_count)s ລາຍການ."

#. module: product_barcodelookup
#: model_terms:ir.ui.view,arch_db:product_barcodelookup.product_fetch_image_wizard_view_form
msgid ""
"<span invisible=\"nb_products_selected &lt;= 1000\">\n"
"                            As only 1000 products can be processed per day, the remaining will be\n"
"                            done tomorrow.\n"
"                        </span>"
msgstr ""
"<span invisible=\"nb_products_selected &lt;= 1000\">\n"
"                            ເນື່ອງຈາກສາມາດປະມວນຜົນໄດ້ພຽງ 1000 ລາຍການຕໍ່ມື້, ສ່ວນທີ່ເຫຼືອຈະ"
"ຖືກ\n"
"                            ປະມວນຜົນໃນມື້ອື່ນ.\n"
"                        </span>"

#. module: product_barcodelookup
