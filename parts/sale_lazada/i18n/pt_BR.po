#. module: sale_lazada
#: model:mail.template,body_html:sale_lazada.inventory_sync_failure
#, fuzzy
msgid ""
"<style>\n"
"                .lazada_table {\n"
"                    width: 100%;\n"
"                    max-width: 900px;\n"
"                    border-collapse: collapse;\n"
"                }\n"
"\n"
"                .lazada_table th,\n"
"                .lazada_table td {\n"
"                    border: 1px solid #888;\n"
"                }\n"
"\n"
"                .lazada_table th {\n"
"                    white-space: nowrap;\n"
"                }\n"
"\n"
"                .lazada_table thead th {\n"
"                    padding: 0.5em 0.5em;\n"
"                    text-align: center;\n"
"                    border-bottom: 1px solid #888;\n"
"                }\n"
"\n"
"                .lazada_table tbody th,\n"
"                .lazada_table tbody td {\n"
"                    padding: 0.5em 0.5em 1em;\n"
"                    vertical-align: top;\n"
"                }\n"
"            </style>\n"
"            <body><div>\n"
"                <p>The synchronization of the inventory for Lazada Shop\n"
"                    <b><t t-out=\"ctx.get('lazada_shop') or ''\">REF</t></"
"b>\n"
"                    encountered some errors and was not completed.</p>\n"
"                <p>Here are the errors sent by Lazada: </p>\n"
"                <table class=\"lazada_table\">\n"
"                    <thead>\n"
"                        <tr>\n"
"                            <th>Product Internal Reference(s)</th>\n"
"                            <th>Message</th>\n"
"                        </tr>\n"
"                    </thead>\n"
"                    <tbody>\n"
"                        <tr t-foreach=\"ctx.get('error_messages')\" t-"
"as=\"error\">\n"
"                            <th><t t-out=\"', '.join(error['default_codes'])"
"\"/></th>\n"
"                            <td>\n"
"                                <t t-if=\"error['message']\" t-"
"out=\"error['message']\"/>\n"
"                                <t t-else=\"\">An unknown error occurred "
"during the synchronisation with Lazada.\n"
"                                    Unfortunately you need to manually check "
"if the available quantity for the product is correct or not.\n"
"                                    If the problem persists, contact <a "
"href=\"https://www.odoo.com/help/\">Odoo support </a>.\n"
"                                </t>\n"
"                            </td>\n"
"                        </tr>\n"
"                    </tbody>\n"
"                </table>\n"
"            </div>\n"
"        </body>"
msgstr ""
"<style>\n"
"                .lazada_table {\n"
"                    width: 100%;\n"
"                    max-width: 900px;\n"
"                    border-collapse: collapse;\n"
"                }\n"
"\n"
"                .lazada_table th,\n"
"                .lazada_table td {\n"
"                    border: 1px solid #888;\n"
"                }\n"
"\n"
"                .lazada_table th {\n"
"                    espaço em branco: nowrap;\n"
"                }\n"
"\n"
"                .lazada_table thead th {\n"
"                    preenchimento: 0,5em 0,5em;\n"
"                    alinhamento do texto: centralizado;\n"
"                    borda inferior: 1px sólida #888;\n"
"                }\n"
"\n"
"                .lazada_table tbody th,\n"
".lazada_table tbody td {\n"
"                    padding: 0.5em 0.5em 1em;\n"
"                    vertical-align: top;\n"
"} </style>\n"
"            <body><div>\n"
"                <p> A sincronização do Inventário para a Lazada Shop <b><t t-"
"out=\"ctx.get('lazada_shop') or ''\">REF</t></b>encontrou alguns erros e não "
"foi concluída.</p>\n"
"                <p>Aqui estão os erros enviados pela Lazada: </p>\n"
"                <table class=\"lazada_table\">\n"
"                   <thead>\n"
"                        <tr> \n"
"                           <th> Referência(s) interna(s) do produto</th>\n"
"                            <th>Mensagem</th>\n"
"                        </tr> </thead>\n"
"                    <tbody> <tr t-foreach=\"ctx.get('error_messages')\" t-"
"as=\"error\">\n"
"                            <th> <t t-out=\"', '.join(error['default_codes'])"
"\"/></th> <td>\n"
"                                <t t-if=\"error['message']\" t-"
"out=\"error['message']\"/> <t t-else=\"\"> Ocorreu um erro desconhecido "
"durante a sincronização com a Lazada.\n"
"Infelizmente, você precisa verificar manualmente se a quantidade disponível "
"para o produto está correta ou não.\n"
"Se o problema persistir, entre em contato com o suporte da Odoo <a "
"href=\"https://www.odoo.com/help/\"> </a> .\n"
"                               </t>\n"
"                            </td> \n"
"                       </tr>\n"
"                    </tbody> \n"
"               </table>\n"
"            </div> \n"
"       </body>"

