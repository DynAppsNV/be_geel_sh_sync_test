#. module: sale_lazada
#: model:mail.template,body_html:sale_lazada.order_sync_failure
msgid ""
"<div>\n"
"                <p>The synchronization of the Lazada order with reference <t t-out=\"ctx.get('lazada_order_ref') or ''\">REF</t> encountered an error and was not completed.</p>\n"
"                <p>Unless the order is cancelled in Lazada, no other synchronization will be attempted.</p>\n"
"                <p>To schedule a new synchronization attempt, proceed as follows:\n"
"                    </p><ol>\n"
"                        <li>Enter the Developer Tools.</li>\n"
"                        <li>Open the form of the Lazada Shop on which the order was placed.</li>\n"
"                        <li>Navigate to the Order Follow-up tab.</li>\n"
"                        <li>Set a date for <em>Last Order Synchronization Date</em> that is anterior to the last status update of the order.</li>\n"
"                        <li>Save the changes and click on the <em>SYNC ORDERS</em> button.</li>\n"
"                    </ol>\n"
"                \n"
"                <p>If the problem persists, contact <a href=\"https://www.odoo.com/help/\">Odoo support</a>.</p>\n"
"            </div>\n"
"        "
msgstr ""
"<div>\n"
"                <p>ການຊິ້ງຂໍ້ມູນຄຳສັ່ງຊື້ Lazada ທີ່ມີລະຫັດອ້າງອີງ <t t-out=\"ctx.get"
"('lazada_order_ref') or ''\">REF</t> ເກີດຂໍ້ຜິດພາດ ແລະ ບໍ່ສຳເລັດ.</p>\n"
"                <p>ນອກຈາກຄຳສັ່ງຊື້ຈະຖືກຍົກເລີກໃນ Lazada ແລ້ວ, ຈະບໍ່ມີການພະຍາຍາມຊິ້ງຂໍ້ມູນຄືນໃ"
"ໝ່.</p>\n"
"                <p>ເພື່ອຕັ້ງເວລາການພະຍາຍາມຊິ້ງຂໍ້ມູນໃໝ່, ໃຫ້ປະຕິບັດຕາມຂັ້ນຕອນດັ່ງນີ້:\n"
"                    </p><ol>\n"
"                        <li>ເຂົ້າໄປທີ່ ເຄື່ອງມືນັກພັດທະນາ (Developer Tools).</li>\n"
"                        <li>ເປີດແບບຟອມຂອງຮ້ານຄ້າ Lazada ທີ່ຄຳສັ່ງຊື້ຖືກສ້າງຂຶ້ນ.</li>\n"
"                        <li>ໄປທີ່ແຖບ ການຕິດຕາມຄຳສັ່ງຊື້ (Order Follow-up).</li>\n"
"                        <li>ກຳນົດວັນທີ <em>Last Order Synchronization Date</em> "
"ໃຫ້ກ່ອນວັນທີອັບເດດສະຖານະລ່າສຸດຂອງຄຳສັ່ງຊື້.</li>\n"
"                        <li>ບັນທຶກການປ່ຽນແປງ ແລະ ຄລິກໃສ່ປຸ່ມ <em>SYNC ORDERS</em>.</"
"li>\n"
"                    </ol>\n"
"                \n"
"                <p>ຫາກຍັງພົບຫາຫາຢູ່, ກະລຸນາຕິດຕໍ່ <a href=\"https://www.odoo.com/"
"help/\">ຝ່າຍຊ່ວຍເຫຼືອຂອງ Odoo</a>.</p>\n"
"            </div>\n"
"        "

#. module: sale_lazada
#: model_terms:ir.ui.view,arch_db:sale_lazada.lazada_shop_form
msgid ""
"<strong>Authorization Failed: </strong>\n"
"                    An unexpected error occurred during authorization. Please try again."
msgstr ""
"<strong>ການຢືນຢັນສິດຫຼົ້ມເຫຼວ: </strong>\n"
"                    ເກີດຂໍ້ຜິດພາດທີ່ບໍ່ຄາດຄິດໃນລະຫວ່າງການຢືນຢັນສິດ. ກະລຸນາລອງໃໝ່ອີກຄັ້ງ."

#. module: sale_lazada
#: model:mail.template,body_html:sale_lazada.inventory_sync_failure
msgid ""
"<style>\n"
"                .lazada_table {\n"
"                    width: 100%;\n"
"                    max-width: 900px;\n"
"                    border-collapse: collapse;\n"
"                }\n"
"\n"
"                .lazada_table th,\n"
"                .lazada_table td {\n"
"                    border: 1px solid #888;\n"
"                }\n"
"\n"
"                .lazada_table th {\n"
"                    white-space: nowrap;\n"
"                }\n"
"\n"
"                .lazada_table thead th {\n"
"                    padding: 0.5em 0.5em;\n"
"                    text-align: center;\n"
"                    border-bottom: 1px solid #888;\n"
"                }\n"
"\n"
"                .lazada_table tbody th,\n"
"                .lazada_table tbody td {\n"
"                    padding: 0.5em 0.5em 1em;\n"
"                    vertical-align: top;\n"
"                }\n"
"            </style>\n"
"            <body><div>\n"
"                <p>The synchronization of the inventory for Lazada Shop\n"
"                    <b><t t-out=\"ctx.get('lazada_shop') or ''\">REF</t></b>\n"
"                    encountered some errors and was not completed.</p>\n"
"                <p>Here are the errors sent by Lazada: </p>\n"
"                <table class=\"lazada_table\">\n"
"                    <thead>\n"
"                        <tr>\n"
"                            <th>Product Internal Reference(s)</th>\n"
"                            <th>Message</th>\n"
"                        </tr>\n"
"                    </thead>\n"
"                    <tbody>\n"
"                        <tr t-foreach=\"ctx.get('error_messages')\" t-as=\"error\">\n"
"                            <th><t t-out=\"', '.join(error['default_codes'])\"/></th>\n"
"                            <td>\n"
"                                <t t-if=\"error['message']\" t-out=\"error['message']\"/>\n"
"                                <t t-else=\"\">An unknown error occurred during the synchronisation with Lazada.\n"
"                                    Unfortunately you need to manually check if the available quantity for the product is correct or not.\n"
"                                    If the problem persists, contact <a href=\"https://www.odoo.com/help/\">Odoo support </a>.\n"
"                                </t>\n"
"                            </td>\n"
"                        </tr>\n"
"                    </tbody>\n"
"                </table>\n"
"            </div>\n"
"        </body>"
msgstr ""
"<style>\n"
"                .lazada_table {\n"
"                    width: 100%;\n"
"                    max-width: 900px;\n"
"                    border-collapse: collapse;\n"
"                }\n"
"\n"
"                .lazada_table th,\n"
"                .lazada_table td {\n"
"                    border: 1px solid #888;\n"
"                }\n"
"\n"
"                .lazada_table th {\n"
"                    white-space: nowrap;\n"
"                }\n"
"\n"
"                .lazada_table thead th {\n"
"                    padding: 0.5em 0.5em;\n"
"                    text-align: center;\n"
"                    border-bottom: 1px solid #888;\n"
"                }\n"
"\n"
"                .lazada_table tbody th,\n"
"                .lazada_table tbody td {\n"
"                    padding: 0.5em 0.5em 1em;\n"
"                    vertical-align: top;\n"
"                }\n"
"            </style>\n"
"            <body><div>\n"
"                <p>ການຊິ້ງຂໍ້ມູນສາງສິນຄ້າສຳລັບຮ້ານຄ້າ Lazada \n"
"                    <b><t t-out=\"ctx.get('lazada_shop') or ''\">REF</t></b>"
"\n"
"                    ເກີດຂໍ້ຜິດພາດບາງຢ່າງ ແລະ ບໍ່ສຳເລັດ.</p>\n"
"                <p>ນີ້ຄືຂໍ້ຜິດພາດທີ່ສົ່ງມາຈາກ Lazada: </p>\n"
"                <table class=\"lazada_table\">\n"
"                    <thead>\n"
"                        <tr>\n"
"                            <th>ລະຫັດອ້າງອີງພາຍໃນຂອງສິນຄ້າ</th>\n"
"                            <th>ຂໍ້ຄວາມ</th>\n"
"                        </tr>\n"
"                    </thead>\n"
"                    <tbody>\n"
"                        <tr t-foreach=\"ctx.get('error_messages')\" t-"
"as=\"error\">\n"
"                            <th><t t-out=\"', '.join(error['default_codes'])"
"\"/></th>\n"
"                            <td>\n"
"                                <t t-if=\"error['message']\" t-"
"out=\"error['message']\"/>\n"
"                                <t t-else=\"\">ເກີດຂໍ້ຜິດພາດທີ່ບໍ່ຮູ້ຈັກໃນລະຫວ່າງການຊິ້ງຂໍ້ມູນ"
"ກັບ Lazada.\n"
"                                    ຂໍອະໄພ, ທ່ານຈຳເປັນຕ້ອງກວດສອບຈຳນວນສິນຄ້າທີ່ມີຢູ່ດ້ວຍຕົນ"
"ເອງວ່າຖືກຕ້ອງຫຼືບໍ່.\n"
"                                    ຫາກຍັງພົບບັນຫາຢູ່, ກະລຸນາຕິດຕໍ່ <a href=\"https://"
"www.odoo.com/help/\">ຝ່າຍຊ່ວຍເຫຼືອຂອງ Odoo </a>.\n"
"                                </t>\n"
"                            </td>\n"
"                        </tr>\n"
"                    </tbody>\n"
"                </table>\n"
"            </div>\n"
"        </body>"

