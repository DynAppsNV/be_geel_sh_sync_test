"                    padding: 0.5em 0.5em 1em;\n"
"                    vertical-align: top;\n"
"                }\n"
"            </style>\n"
"            <body><div>\n"
"                <p>Sinkronisasi inventaris Lazada Shop\n"
"                    <b><t t-out=\"ctx.get('lazada_shop') or ''\">REF</t></b>"
"\n"
"                    mengalami kesalahan dan tidak selesai.</p>\n"
"                <p>Berikut kesalahan yang dikirim oleh Lazada: </p>\n"
"                <table class=\"lazada_table\">\n"
"                    <thead>\n"
"                        <tr>\n"
"                            <th>Referensi Internal Produk</th>\n"
"                            <th>Pesan</th>\n"
"                        </tr>\n"
"                    </thead>\n"
"                    <tbody>\n"
"                        <tr t-foreach=\"ctx.get('error_messages')\" t-"
"as=\"error\">\n"
"                            <th><t t-out=\"', '.join(error['default_codes'])"
