<?xml version="1.0" encoding="UTF-8" ?>
<odoo noupdate="1">
    <record id="auditlog_rule_res_currency" model="auditlog.rule">
        <field name="name">Currencies</field>
        <field name="model_id" ref="base.model_res_currency" />
        <field name="log_type">fast</field>
        <field name="log_read" eval="False" />
        <field name="log_unlink" eval="True" />
        <field name="log_write" eval="True" />
        <field name="log_create" eval="True" />
    </record>
    <record id="auditlog_rule_iap_accounts" model="auditlog.rule">
        <field name="name">IAP Accounts</field>
        <field name="model_id" ref="iap.model_iap_account" />
        <field name="log_type">fast</field>
        <field name="log_read" eval="False" />
        <field name="log_unlink" eval="True" />
        <field name="log_write" eval="True" />
        <field name="log_create" eval="True" />
    </record>
    <function model="auditlog.rule" name="set_to_confirmed">
        <value
            model="auditlog.rule"
            eval="obj().search([('state', '=', 'draft')]).ids"
        />
    </function>
</odoo>
