<?xml version="1.0" encoding="UTF-8" ?>
<odoo>
    <record id="res_config_settings_view_form_purchase" model="ir.ui.view">
        <field
            name="name"
        >res.config.settings.view.form.purchase.inherit.xx.approval.dynamic.user</field>
        <field name="model">res.config.settings</field>
        <field
            name="inherit_id"
            ref="purchase.res_config_settings_view_form_purchase"
        />
        <field name="arch" type="xml">
            <xpath expr="//app[@name='purchase']" position="inside">
                <block
                    title="Board Approval Signature"
                    name="board_sign_setting_container"
                >
                    <setting
                        string="Signature position"
                        help="Position and size of the signature field placed on the last page of the PO PDF (values between 0 and 1)."
                    >
                        <div class="row mt8">
                            <div class="col-lg-6">
                                <label
                                    for="xx_board_sign_pos_x"
                                    string="X (left → right)"
                                />
                                <field name="xx_board_sign_pos_x" />
                            </div>
                            <div class="col-lg-6">
                                <label
                                    for="xx_board_sign_pos_y"
                                    string="Y (top → bottom)"
                                />
                                <field name="xx_board_sign_pos_y" />
                            </div>
                        </div>
                        <div class="row mt4">
                            <div class="col-lg-6">
                                <label for="xx_board_sign_width" string="Width" />
                                <field name="xx_board_sign_width" />
                            </div>
                            <div class="col-lg-6">
                                <label for="xx_board_sign_height" string="Height" />
                                <field name="xx_board_sign_height" />
                            </div>
                        </div>
                    </setting>
                </block>
            </xpath>
        </field>
    </record>
</odoo>
