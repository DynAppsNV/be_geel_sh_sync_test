#. module: hr_appraisal_survey
#: model:mail.template,body_html:hr_appraisal_survey.mail_template_appraisal_ask_feedback
msgid ""
"<p style=\"margin: 0px; padding: 0px; font-size: 13px;\">\n"
"                    Dear <t t-out=\"object.partner_id.name or 'participant'\">[participant]</t>,\n"
"                    <br/>\n"
"                    As part of our 360° feedback process, <t t-out=\"ctx.get('logged_user')\">[Current user]</t> would love\n"
"                    to get your insights on <t t-out=\"ctx.get('employee')\">[the employee]</t>'s performance.\n"
"                    <br/>\n"
"                    Your feedback is valuable in helping us recognize strengths and identify growth opportunities.\n"
"                    <br/>\n"
"                    It should only take a few minutes, and you can submit your feedback via the link below:\n"
"                    <br/>\n"
"                    </p><div class=\"text-center my-4\">\n"
"                        <a t-att-href=\"object.get_start_url()\" t-attf-style=\"background-color: {{user.company_id.email_secondary_color or '#875A7B'}}; padding: 8px 16px 8px 16px; text-decoration: none; color: {{user.company_id.email_primary_color or '#FFFFFF'}}; border-radius: 5px; font-size:13px;\">\n"
"                            Give your feedback\n"
"                        </a>\n"
"                    </div>\n"
"                    Please complete the survey before <t t-out=\"ctx.get('deadline')\">[the specified deadline]</t>.\n"
"                    <br/>\n"
"                    Thank you for your time and honesty!\n"
"                    <br/>\n"
"                    <t t-if=\"ctx.get('user_body')\">\n"
"                        <div class=\"my-3 py-2 px-3 bg-secondary\">\n"
"                            <t t-out=\"ctx.get('user_body')\">[Optional comment]</t>\n"
"                        </div>\n"
"                    </t>\n"
"                \n"
"            "
msgstr ""
"<p style=\"margin: 0px; padding: 0px; font-size: 13px;\">\n"
"                    ຮຽນ <t t-out=\"object.partner_id.name or 'participant'\">"
"[participant]</t>,\n"
"                    <br/>\n"
"                    ໃນຖານະເປັນສ່ວນໜຶ່ງຂອງຂະບວນການຄຳຄິດເຫັນແບບ 360°, <t t-"
"out=\"ctx.get('logged_user')\">[Current user]</t> ຢາກ\n"
"                    ຂໍຄວາມຄິດເຫັນຂອງທ່ານກ່ຽວກັບຜົນງານຂອງ <t t-out=\"ctx.get"
"('employee')\">[the employee]</t>.\n"
"                    <br/>\n"
"                    ຄຳຄິດເຫັນຂອງທ່ານມີຄຸນຄ່າຫຼາຍໃນການຊ່ວຍໃຫ້ພວກເຮົາຮັບຮູ້ຈຸດແຂງ ແລະ ກໍານົດໂອກ"
"າດໃນການເຕີບໂຕ.\n"
"                    <br/>\n"
"                    ມັນຈະໃຊ້ເວລາພຽງແຕ່ບໍ່ກີ່ນາທີ, ແລະ ທ່ານສາມາດສົ່ງຄຳຄິດເຫັນຜ່ານລິ້ງລຸ່ມນີ້:\n"
"                    <br/>\n"
"                    </p><div class=\"text-center my-4\">\n"
"                        <a t-att-href=\"object.get_start_url()\" t-attf-"
"style=\"background-color: {{user.company_id.email_secondary_color or "
"'#875A7B'}}; padding: 8px 16px 8px 16px; text-decoration: none; color: {"
"{user.company_id.email_primary_color or '#FFFFFF'}}; border-radius: 5px; "
"font-size:13px;\">\n"
"                            ໃຫ້ຄຳຄິດເຫັນຂອງທ່ານ\n"
"                        </a>\n"
"                    </div>\n"
"                    ກະລຸນາຕອບແບບສອບຖາມໃຫ້ສຳເລັດກ່ອນ <t t-out=\"ctx.get"
"('deadline')\">[the specified deadline]</t>.\n"
"                    <br/>\n"
"                    ຂອບໃຈສຳລັບເວລາ ແລະ ຄວາມຈິງໃຈຂອງທ່ານ!\n"
"                    <br/>\n"
"                    <t t-if=\"ctx.get('user_body')\">\n"
"                        <div class=\"my-3 py-2 px-3 bg-secondary\">\n"
"                            <t t-out=\"ctx.get('user_body')\">[Optional "
"comment]</t>\n"
"                        </div>\n"
"                    </t>\n"
"                \n"
"            "

