<?xml version="1.0" encoding="utf-8" ?>
<odoo>
    <record id="view_move_form" model="ir.ui.view">
        <field name="name">account.move.form.inherit.xx_intrastat</field>
        <field name="model">account.move</field>
        <field name="inherit_id" ref="account.view_move_form" />
        <field name="arch" type="xml">
            <page name="aml_tab" position="after">
                <page string="Intrastat">
                    <field name="xx_intrastat_line_ids">
                        <list editable="bottom">
                            <field name="intrastat_code_id" />
                            <field name="intrastat_commodity_code" />
                            <field name="intrastat_country_code" />
                            <field name="intrastat_supplementary_units_amount" />
                            <field name="intrastat_supplementary_units_code" />
                            <field name="intrastat_weight" />
                            <field name="intrastat_value" />
                            <field name="intrastat_statistical_value" />
                        </list>
                    </field>
                </page>
            </page>
        </field>
    </record>
</odoo>
