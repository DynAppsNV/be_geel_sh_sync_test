#. module: planning
#: model:mail.template,body_html:planning.email_template_shift_switch_email
msgid ""
"<div>\n"
"                    <p t-if=\"ctx.get('old_assignee_name')\">Dear <t t-"
"out=\"ctx['old_assignee_name']\">Anita Oliver</t>,</p>\n"
"                    <p t-else=\"\">Hello,</p>\n"
"                    <br/>\n"
"                    <p>\n"
"                        The following shift that you requested to switch has "
"been re-assigned\n"
"                        <t t-if=\"ctx.get('new_assignee_name')\"> to <t t-"
"out=\"ctx['new_assignee_name']\">Marc Demo</t></t>.\n"
"                    </p>\n"
"                    <table style=\"margin-left: 30px;\">\n"
"                        <tr t-if=\"(ctx.get('start_datetime') and "
"ctx.get('end_datetime'))                                   or "
"ctx.get('allocated_hours')                                   or "
"ctx.get('allocated_percentage')\">\n"
"                            <th style=\"padding: 5px; text-align: left;"
"\">Date</th>\n"
"                            <td style=\"padding: 5px;\">\n"
"                                <span t-if=\"ctx.get('start_datetime') and "
"ctx.get('end_datetime')\" t-out=\"'%s ⟶ %s' % "
"(                                     ctx['start_datetime'],                                     "
"ctx['end_datetime'],                                 )\">\n"
"                                    05/31/2021, 8:00 AM ⟶ 05/31/2021, 4:00 "
"PM\n"
"                                </span>\n"
"                                <span t-if=\"ctx.get('allocated_hours')\" "
"style=\"opacity: 0.5;\">\n"
"                                    (<t t-out=\"ctx['allocated_hours']"
"\">4:00</t>h)\n"
"                                </span>\n"
"                                <span t-if=\"ctx.get('allocated_percentage') "
"and ctx['allocated_percentage'] != '100'\" style=\"opacity: 0.5;\">\n"
"                                    (<t t-out=\"ctx['allocated_percentage']"
"\">50</t>%)\n"
"                                </span>\n"
"                            </td>\n"
"                        </tr>\n"
"                        <tr t-if=\"object.role_id\">\n"
"                            <th style=\"padding: 5px; text-align: left;"
"\">Role</th>\n"
"                            <td style=\"padding: 5px;\" t-"
"out=\"object.role_id.name or ''\">Bartender</td>\n"
"                        </tr>\n"
"                        <tr t-if=\"hasattr(object, 'project_id') and "
"object.project_id\">\n"
"                            <th style=\"padding: 5px; text-align: left;"
"\">Project</th>\n"
"                            <td style=\"padding: 5px;\" t-"
"out=\"object.sudo().project_id.name or ''\">Gathering</td>\n"
"                        </tr>\n"
"                        <tr t-if=\"hasattr(object, 'sale_line_id') and "
"object.sale_line_id\">\n"
"                            <th style=\"padding: 5px; text-align: left;"
"\">Sales Order Item</th>\n"
"                            <td style=\"padding: 5px;\" t-"
"out=\"object.sudo().sale_line_id.name or ''\">Coffee</td>\n"
"                        </tr>\n"
"                        <tr t-if=\"hasattr(object, 'name') and "
"object.name\">\n"
"                            <th style=\"padding: 5px; text-align: left;"
"\">Note</th>\n"
"                            <td style=\"padding: 5px;\" t-out=\"object.name "
"or ''\">/</td>\n"
"                        </tr>\n"
"                    </table>\n"
"                    <br/>\n"
"                </div>\n"
"            "
msgstr ""
"<div>\n"
"                    <p t-if=\"ctx.get('old_assignee_name')\">ຮຽນ <t t-"
"out=\"ctx['old_assignee_name']\">Anita Oliver</t>,</p>\n"
"                    <p t-else=\"\">ສະບາຍດີ,</p>\n"
"                    <br/>\n"
"                    <p>\n"
"                        ຜັດວຽກຕໍ່ໄປນີ້ທີ່ທ່ານໄດ້ຮ້ອງຂໍປ່ຽນ ໄດ້ຖືກມອບໝາຍໃໝ່ແລ້ວ\n"
"                        <t t-if=\"ctx.get('new_assignee_name')\"> ໃຫ້ກັບ <t t-"
"out=\"ctx['new_assignee_name']\">Marc Demo</t></t>.\n"
"                    </p>\n"
"                    <table style=\"margin-left: 30px;\">\n"
"                        <tr t-if=\"(ctx.get('start_datetime') and "
"ctx.get('end_datetime'))                                   or "
"ctx.get('allocated_hours')                                   or "
"ctx.get('allocated_percentage')\">\n"
"                            <th style=\"padding: 5px; text-align: left;"
"\">ວັນທີ</th>\n"
"                            <td style=\"padding: 5px;\">\n"
"                                <span t-if=\"ctx.get('start_datetime') and "
"ctx.get('end_datetime')\" t-out=\"'%s ⟶ %s' % "
"(                                     ctx['start_datetime'],                                     "
"ctx['end_datetime'],                                 )\">\n"
"                                    05/31/2021, 8:00 AM ⟶ 05/31/2021, 4:00 "
"PM\n"
"                                </span>\n"
"                                <span t-if=\"ctx.get('allocated_hours')\" "
"style=\"opacity: 0.5;\">\n"
"                                    (<t t-out=\"ctx['allocated_hours']"
"\">4:00</t>ຊມ)\n"
"                                </span>\n"
"                                <span t-if=\"ctx.get('allocated_percentage') "
"and ctx['allocated_percentage'] != '100'\" style=\"opacity: 0.5;\">\n"
"                                    (<t t-out=\"ctx['allocated_percentage']"
"\">50</t>%)\n"
"                                </span>\n"
"                            </td>\n"
"                        </tr>\n"
"                        <tr t-if=\"object.role_id\">\n"
"                            <th style=\"padding: 5px; text-align: left;"
"\">ບົດບາດ</th>\n"
"                            <td style=\"padding: 5px;\" t-"
"out=\"object.role_id.name or ''\">Bartender</td>\n"
"                        </tr>\n"
"                        <tr t-if=\"hasattr(object, 'project_id') and "
"object.project_id\">\n"
"                            <th style=\"padding: 5px; text-align: left;"
"\">ໂຄງການ</th>\n"
"                            <td style=\"padding: 5px;\" t-"
"out=\"object.sudo().project_id.name or ''\">Gathering</td>\n"
"                        </tr>\n"
"                        <tr t-if=\"hasattr(object, 'sale_line_id') and "
"object.sale_line_id\">\n"
"                            <th style=\"padding: 5px; text-align: left;"
"\">ລາຍການຄຳສັ່ງຂາຍ</th>\n"
"                            <td style=\"padding: 5px;\" t-"
"out=\"object.sudo().sale_line_id.name or ''\">Coffee</td>\n"
"                        </tr>\n"
"                        <tr t-if=\"hasattr(object, 'name') and "
"object.name\">\n"
"                            <th style=\"padding: 5px; text-align: left;"
"\">ໝາຍເຫດ</th>\n"
"                            <td style=\"padding: 5px;\" t-out=\"object.name "
"or ''\">/</td>\n"
"                        </tr>\n"
"                    </table>\n"
"                    <br/>\n"
"                </div>\n"
"            "

