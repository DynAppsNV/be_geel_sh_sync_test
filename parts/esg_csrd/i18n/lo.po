#. module: esg_csrd
#: model:mail.template,body_html:esg_csrd.mail_template_esg_metric_ask_feedback
msgid ""
"<t t-set=\"logged_user\" t-value=\"ctx.get('logged_user')\"/>\n"
"                <t t-set=\"company_name\" t-value=\"ctx.get('company_name')\"/>\n"
"                <t t-set=\"deadline\" t-value=\"ctx.get('deadline')\"/>\n"
"                <div style=\"margin: 0px; padding: 0px;\">\n"
"                    <p style=\"margin: 0px; padding: 0px; font-size: 13px;\">\n"
"                        </p><p style=\"margin-left:5px\">Dear <t t-out=\"object.partner_id.name or 'stakeholder'\">[Stakeholder]</t></p>\n"
"                        <span>\n"
"                            <t t-out=\"logged_user\">[Current user]</t> invites you to participate in the CSRD double materiality review for <t t-out=\"company_name\">[Company Name]</t>. We are looking for your input on: <br/>\n"
"                            - How the company impacts the environment, society, and the economy. <br/>\n"
"                            - How these impacts could affect the company financially. <br/>\n"
"                            Please complete your review by <t t-out=\"deadline\">[specified deadline]</t> to help us meet CSRD requirements. Your expertise is important for an accurate assessment. </span>\n"
"                        <br/> Thank you for your contribution. <br/>\n"
"                        Best regards, <t t-out=\"logged_user\">[Current user]</t>\n"
"                        <br/><br/>\n"
"                        <div style=\"margin: 16px 0px 16px 0px; text-align: center;\">\n"
"                            <a t-att-href=\"object.get_start_url()\" t-attf-style=\"background-color: {{user.company_id.email_secondary_color or '#875A7B'}}; padding: 8px 16px 8px 16px; text-decoration: none; color: {{user.company_id.email_primary_color or '#FFFFFF'}}; border-radius: 5px; font-size:13px;\">\n"
"                                Start the Review\n"
"                            </a>\n"
"                        </div>\n"
"                    \n"
"                </div>\n"
"            "
msgstr ""
"<t t-set=\"logged_user\" t-value=\"ctx.get('logged_user')\"/>\n"
"                <t t-set=\"company_name\" t-value=\"ctx.get('company_name')"
"\"/>\n"
"                <t t-set=\"deadline\" t-value=\"ctx.get('deadline')\"/>\n"
"                <div style=\"margin: 0px; padding: 0px;\">\n"
"                    <p style=\"margin: 0px; padding: 0px; font-size: 13px;\">"
"\n"
"                        </p><p style=\"margin-left:5px\">ຮຽນ <t t-"
"out=\"object.partner_id.name or 'stakeholder'\">[ຜູ້ມີສ່ວນຮ່ວມ]</t></p>\n"
"                        <span>\n"
"                            <t t-out=\"logged_user\">[ຜູ້ໃຊ້ປະຈຸບັນ]</t> ຂໍເຊີນທ່ານເຂົ້"
"າຮ່ວມການທົບທວນຄວາມສຳຄັນສອງດ້ານ (double materiality) ຂອງ CSRD ສຳລັບ <t t-"
"out=\"company_name\">[ຊື່ບໍລິສັດ]</t>. ພວກເຮົາຕ້ອງການຄວາມຄິດເຫັນຂອງທ່ານກ່ຽວກັບ: <br/>\n"
"                            - ບໍລິສັດສົ່ງຜົນກະທົບຕໍ່ສິ່ງແວດລ້ອມ, ສັງຄົມ ແລະ ເສດຖະກິດແນວໃດ. "
"<br/>\n"
"                            - ຜົນກະທົບເຫຼົ່ານີ້ສາມາດສົ່ງຜົນກະທົບຕໍ່ການເງິນຂອງບໍລິສັດແນວໃດ. "
"<br/>\n"
"                            ກະລຸນາເຮັດການທົບທວນໃຫ້ສຳເລັດພາຍໃນ <t t-"
"out=\"deadline\">[ກຳນົດເວລາທີ່ລະບຸ]</t> ເພື່ອຊ່ວຍໃຫ້ພວກເຮົາປະຕິບັດຕາມຂໍ້ກຳນົດຂອງ CSRD. ຄວາມ"
"ຊ່ຽວຊານຂອງທ່ານມີຄວາມສຳຄັນຫຼາຍສຳລັບການປະເມີນທີ່ຖືກຕ້ອງ. </span>\n"
"                        <br/> ຂໍຂອບໃຈສຳລັບການປະກອບສ່ວນຂອງທ່ານ. <br/>\n"
"                        ດ້ວຍຄວາມນັບຖື, <t t-out=\"logged_user\">[ຜູ້ໃຊ້ປະຈຸບັນ]</t>\n"
"                        <br/><br/>\n"
"                        <div style=\"margin: 16px 0px 16px 0px; text-align: "
"center;\">\n"
"                            <a t-att-href=\"object.get_start_url()\" t-attf-"
"style=\"background-color: {{user.company_id.email_secondary_color or "
"'#875A7B'}}; padding: 8px 16px 8px 16px; text-decoration: none; color: {"
"{user.company_id.email_primary_color or '#FFFFFF'}}; border-radius: 5px; "
"font-size:13px;\">\n"
"                                ເລີ່ມການທົບທວນ\n"
"                            </a>\n"
"                        </div>\n"
"                    \n"
"                </div>\n"
"            "

#. module: esg_csrd
