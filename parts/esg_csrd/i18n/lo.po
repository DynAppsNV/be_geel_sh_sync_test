#. module: esg_csrd
#: model_terms:knowledge.article,template_body:esg_csrd.esg_csrd_knowledge_article_template_vsm_b2
#: model_terms:knowledge.article,template_body:esg_csrd.esg_csrd_knowledge_article_template_vsm_c2
msgid "Water and Marine Resources"
msgstr "ຊັບພະຍາກອນນ້ຳ ແລະ ທາງທະເລ"

#. module: esg_csrd
#: model_terms:knowledge.article,template_body:esg_csrd.esg_csrd_knowledge_article_template_csrd_appendix_environmental_a
msgid ""
"Water and marine data cover all operational sites within the organizational boundary,\n"
"                including production facilities, offices, and logistics hubs."
msgstr ""
"ຂໍ້ມູນນ້ຳ ແລະ ທາງທະເລຄອບຄຸມທຸກສະຖານທີ່ດຳເນີນງານພາຍໃນຂອບເຂດຂອງອົງກອນ,\n"
"                ລວມທັງໂຮງງານຜະລິດ, ຫ້ອງການ, ແລະ ສູນໂລຈິສຕິກ."

#. module: esg_csrd
#: model_terms:knowledge.article,template_body:esg_csrd.esg_csrd_knowledge_article_template_csrd_esrs_e3
msgid ""
"Water and marine resource management are integrated within <strong>{{ company_name }}</strong>'s overall environmental and social strategy.\n"
"                        Interconnections with climate resilience, pollution control, and\n"
"                        biodiversity are assessed jointly to avoid duplication and ensure data\n"
"                        consistency."
msgstr ""
"ການຄຸ້ມຄອງຊັບພະຍາກອນນ້ຳ ແລະ ທາງທະເລ ແມ່ນຖືກເຊື່ອມໂຍງເຂົ້າໃນຍຸດທະສາດດ້ານສິ່ງແວດລ້ອມ ແລະ ສັງຄົມໂ"
"ດຍລວມຂອງ <strong>{{ company_name }}</strong>.\n"
"                        ຄວາມກ່ຽວພັນກັບຄວາມສາມາດໃນການຟື້ນຕົວດ້ານສະພາບພູມອາກາດ, ການຄວບຄຸ"
"ມມົນລະພິດ, ແລະ\n"
"                        ຄວາມຫຼາກຫຼາຍທາງຊີວະພາບ ແມ່ນຖືກປະເມີນຮ່ວມກັນເພື່ອຫຼີກເວັ້ນການຊ້ຳຊ້ອນ ແ"
"ລະ ຮັບປະກັນຄວາມ\n"
"                        ຕໍ່ເນື່ອງຂອງຂໍ້ມູນ."

#. module: esg_csrd
#: model_terms:ir.actions.act_window,help:esg_csrd.action_view_metrics
msgid "Water and marine resources"
msgstr "ຊັບພະຍາກອນນ້ຳ ແລະ ທາງທະເລ"

#. module: esg_csrd
#: model_terms:knowledge.article,template_body:esg_csrd.esg_csrd_knowledge_article_template_csrd_esrs_e3
msgid "Water consumed in high-stress areas"
msgstr "ນ້ຳທີ່ຖືກຊົມໃຊ້ໃນພື້ນທີ່ທີ່ມີຄວາມຕຶງຄຽດດ້ານນ້ຳສູງ"

#. module: esg_csrd
#: model_terms:knowledge.article,template_body:esg_csrd.esg_csrd_knowledge_article_template_csrd_esrs_e3
msgid "Water recycled and reused"
msgstr "ນ້ຳທີ່ຖືກນຳມາລີໄຊເຄິນ ແລະ ນຳໃຊ້ຄືນ"

#. module: esg_csrd
#: model_terms:knowledge.article,template_body:esg_csrd.esg_csrd_knowledge_article_template_csrd_basic_for_prepation
msgid ""
"We continuously refine these methodologies and aim to enhance the accuracy of\n"
"                        estimated data in future reporting periods."
msgstr ""
"ພວກເຮົາປັບປຸງວິທີການເຫຼົ່ານີ້ຢ່າງຕໍ່ເນື່ອງ ແລະ ມຸ່ງໝັ້ນທີ່ຈະເພີ່ມຄວາມຊັດເຈນຂອງ\n"
"                        ຂໍ້ມູນຄາດຄະເນໃນໄລຍະເວລາການລາຍງານໃນອະນາຄົດ."

#. module: esg_csrd
#: model:ir.model.fields,field_description:esg_csrd.field_esg_metric__website_message_ids
msgid "Website Messages"
msgstr "ຂໍ້ຄວາມຈາກເວັບໄຊ"

#. module: esg_csrd
#: model:ir.model.fields,help:esg_csrd.field_esg_metric__website_message_ids
msgid "Website communication history"
msgstr "ປະຫວັດການສື່ສານຜ່ານເວັບໄຊ"

#. module: esg_csrd
#: model_terms:survey.survey,description:esg_csrd.esg_metric_review_template
msgid ""
"Welcome to this CSRD Double Materiality Stakeholder Review, <br><br>\n"
"                    You've been asked to participate to a CSRD Metric Review. <br><br>\n"
"                    We are looking for your input on how the company impacts the environment and how these impacts could affect the company financially."
msgstr ""
"ຍິນດີຕ້ອນຮັບເຂົ້າສູ່ການທົບທວນຄວາມສຳຄັນແບບສອງດ້ານ CSRD ໂດຍຜູ້ມີສ່ວນໄດ້ສ່ວນເສຍ, <br><br>\n"
"                    ທ່ານໄດ້ຮັບການເຊື້ອເຊີນໃຫ້ເຂົ້າຮ່ວມໃນການທົບທວນຕົວຊີ້ວັດ CSRD. <br><br>\n"
"                    ພວກເຮົາຕ້ອງການຄຳຄິດເຫັນຂອງທ່ານກ່ຽວກັບວິທີທີ່ບໍລິສັດສົ່ງຜົນກະທົບຕໍ່ສິ່ງແວດລ້ອມ ແລ"
"ະ ຜົນກະທົບເຫຼົ່ານີ້ອາດຈະສົ່ງຜົນຕໍ່ບໍລິສັດທາງດ້ານການເງິນແນວໃດ."

#. module: esg_csrd
#: model_terms:ir.ui.view,arch_db:esg_csrd.res_config_settings_view_form
msgid ""
"When enabled, ESRS metrics, double materiality assessment, stakeholder "
"review, and the sustainability report are added."
msgstr ""
"ເມື່ອເປີດໃຊ້ງານ, ຕົວຊີ້ວັດ ESRS, ການປະເມີນຄວາມສຳຄັນແບບສອງດ້ານ, ການທົບທວນໂດຍຜູ້ມີສ່ວນໄດ້ສ່ວນເສ"
"ຍ, ແລະ ລາຍງານຄວາມຍືນຍົງຈະຖືກເພີ່ມເຂົ້າ."

#. module: esg_csrd
#: model_terms:knowledge.article,template_body:esg_csrd.esg_csrd_knowledge_article_template_csrd_basic_for_prepation
msgid ""
"When indirect data sources or estimates have been used (e.g., industry\n"
"                        averages or supplier data models), the basis for such estimations is clearly\n"
"                        indicated in the respective topic sections."
msgstr ""
"ເມື່ອມີການນຳໃຊ້ແຫຼ່ງຂໍ້ມູນທາງອ້ອມ ຫຼື ການຄາດຄະເນ (ເຊັ່ນ: ຄ່າສະເລ່ຍຂອງອຸດສາຫະກຳ\n"
"                        ຫຼື ແບບຈຳລອງຂໍ້ມູນຂອງຜູ້ສະໜອງ), ພື້ນຖານຂອງການຄາດຄະເນດັ່ງກ່າວແມ່ນຖື"
"ກ\n"
"                        ລະບຸໄວ້ຢ່າງຊັດເຈນໃນພາກສ່ວນຫົວຂໍ້ທີ່ກ່ຽວຂ້ອງ."

#. module: esg_csrd
#: model_terms:knowledge.article,template_body:esg_csrd.esg_csrd_knowledge_article_template_csrd_basic_for_prepation
msgid ""
"When specific sustainability topics deviate from these default time horizons\n"
"                        (e.g., climate-related targets extending beyond 10 years), the rationale is\n"
"                        provided in the respective disclosure section."
msgstr ""
"ເມື່ອຫົວຂໍ້ຄວາມຍືນຍົງສະເພາະໃດໜຶ່ງແຕກຕ່າງຈາກໄລຍະເວລາເລີ່ມຕົ້ນເຫຼົ່ານີ້\n"
"                        (ເຊັ່ນ: ເປົ້າໝາຍດ້ານສະພາບພູມອາກາດທີ່ຍາວເກີນ 10 ປີ), ເຫດຜົນແມ່ນຈະຖື"
"ກ\n"
"                        ລະບຸໄວ້ໃນພາກສ່ວນການເປີດເຜີຍຂໍ້ມູນທີ່ກ່ຽວຂ້ອງ."

#. module: esg_csrd
#: model_terms:knowledge.article,template_body:esg_csrd.esg_csrd_knowledge_article_template_csrd_metrics_targets
msgid ""
"Where applicable, both absolute and intensity-based data are disclosed to\n"
"                        ensure\n"
"                        comparability and transparency."
msgstr ""
"ໃນກໍລະນີທີ່ກ່ຽວຂ້ອງ, ທັງຂໍ້ມູນແບບສົມບູນ (Absolute) ແລະ ຂໍ້ມູນແບບອີງຕາມຄວາມເຂັ້ມຂຸ້ນ (Intensity) ແ"
"ມ່ນຖືກເປີດເຜີຍ ເພື່ອ\n"
"                        ຮັບປະກັນ\n"
"                        ຄວາມສາມາດໃນການປຽບທຽບ ແລະ ຄວາມໂປ່ງໃສ."

#. module: esg_csrd
#: model_terms:knowledge.article,template_body:esg_csrd.esg_csrd_knowledge_article_template_csrd_appendix_environmental_a
msgid ""
"Where automated measurement is not available, data are estimated using emission\n"
"                factors or mass balance methods consistent with the EU Industrial Emissions\n"
"                Directive (IED) or ISO 14064 guidelines."
msgstr ""
"ໃນກໍລະນີທີ່ບໍ່ມີການວັດແທກແບບອັດຕະໂນມັດ, ຂໍ້ມູນແມ່ນຖືກຄາດຄະເນໂດຍນຳໃຊ້ຄ່າປັດໄຈການປ່ອຍມົນລະພິດ\n"
"                ຫຼື ວິທີການດຸນມວນສານ (Mass balance) ທີ່ສອດຄ່ອງກັບຄຳສັ່ງແນະນຳການປ່ອຍມົນລະພິດ"
"ຈາກອຸດສາຫະກຳ (IED)\n"
"                ຂອງ EU ຫຼື ແນວທາງ ISO 14064."

#. module: esg_csrd
#: model_terms:knowledge.article,template_body:esg_csrd.esg_csrd_knowledge_article_template_csrd_appendix_governance_c
msgid ""
"Where complete data are unavailable, estimates are based on the scope of governance\n"
"                oversight, sample audits, or extrapolation from comparable business units."
msgstr ""
"ໃນກໍລະນີທີ່ບໍ່ມີຂໍ້ມູນຄົບຖ້ວນ, ການຄາດຄະເນແມ່ນອີງຕາມຂອບເຂດຂອງການກວດກາ\n"
"                ດ້ານທຳມາພິບານ, ການກວດສອບຕົວຢ່າງ, ຫຼື ການຄາດຄະເນຈາກໜ່ວຍທຸລະກິດທີ່ປຽບທຽບກັນ"
"ໄດ້."

#. module: esg_csrd
#: model_terms:knowledge.article,template_body:esg_csrd.esg_csrd_knowledge_article_template_csrd_appendix_social_b
msgid ""
"Where data gaps exist, disclose estimation techniques and\n"
"                                    sources."
msgstr ""
"ໃນກໍລະນີທີ່ມີຊ່ອງວ່າງຂອງຂໍ້ມູນ, ໃຫ້ເປີດເຜີຍເຕັກນິກການຄາດຄະເນ ແລະ\n"
"                                    ແຫຼ່ງຂໍ້ມູນ."

#. module: esg_csrd
#: model_terms:knowledge.article,template_body:esg_csrd.esg_csrd_knowledge_article_template_csrd_appendix_social_b
msgid ""
"Where data gaps exist, disclose estimation techniques and data sources."
msgstr ""
"ໃນກໍລະນີທີ່ມີຊ່ອງວ່າງຂອງຂໍ້ມູນ, ໃຫ້ເປີດເຜີຍເຕັກນິກການຄາດຄະເນ ແລະ ແຫຼ່ງຂໍ້ມູນ."

#. module: esg_csrd
#: model_terms:knowledge.article,template_body:esg_csrd.esg_csrd_knowledge_article_template_csrd_appendix_social_b
msgid ""
"Where direct data are unavailable, estimates are derived from sample surveys,\n"
"                        historical trends, or modeled ratios based on comparable products, services,\n"
"                        or regions."
msgstr ""
"ໃນກໍລະນີທີ່ບໍ່ມີຂໍ້ມູນໂດຍກົງ, ການຄາດຄະເນແມ່ນໄດ້ມາຈາກການສຳຫຼວດຕົວຢ່າງ,\n"
"                        ແນວໂນ້ມໃນອະດີດ, ຫຼື ອັດຕາສ່ວນຈຳລອງ ໂດຍອີງຕາມຜະລິດຕະພັນ, ການບໍລິກ"
"ານ,\n"
"                        ຫຼື ພາກພື້ນ ທີ່ປຽບທຽບກັນໄດ້."

#. module: esg_csrd
#: model_terms:knowledge.article,template_body:esg_csrd.esg_csrd_knowledge_article_template_csrd_basic_for_prepation
msgid ""
"Where quantitative metrics are based on estimates, approximations, or partial\n"
"                        data coverage, the methodology and assumptions are explained in the\n"
"                        corresponding disclosure notes."
msgstr ""
"ໃນກໍລະນີທີ່ຕົວຊີ້ວັດທາງປະລິມານແມ່ນອີງຕາມການຄາດຄະເນ, ຄ່າໃກ້ຄຽງ, ຫຼື ການຄຸ້ມຄອງ\n"
"                        ຂໍ້ມູນບາງສ່ວນ, ວິທີການ ແລະ ຂໍ້ສົມມຸດຕິຖານແມ່ນຈະຖືກອະທິບາຍໄວ້ໃນ\n"
"                        ໝາຍເຫດການເປີດເຜີຍຂໍ້ມູນທີ່ກ່ຽວຂ້ອງ."

#. module: esg_csrd
#: model_terms:knowledge.article,template_body:esg_csrd.esg_csrd_knowledge_article_template_csrd_appendix_social_b
msgid ""
"Where relevant, consumer-related indicators (e.g., complaints, product\n"
"                        recalls, satisfaction scores, privacy compliance) undergo external assurance\n"
"                        in line with recognized frameworks such as ISO 9001, ISO 26000, AA1000\n"
"                        Assurance Standard, or regulatory audits."
msgstr ""
"ໃນກໍລະນີທີ່ກ່ຽວຂ້ອງ, ຕົວຊີ້ວັດທີ່ກ່ຽວກັບຜູ້ບໍລິໂພກ (ເຊັ່ນ: ການຮ້ອງຮຽນ, ການຮຽກຄືນ\n"
"                        ຜະລິດຕະພັນ, ຄະແນນຄວາມເພິ່ງພໍໃຈ, ການປະຕິບັດຕາມຄວາມເປັນສ່ວນຕົວ) ຈ"
"ະຜ່ານການຢັ້ງຢືນຈາກພາຍນອກ\n"
"                        ຕາມຂອບວຽກທີ່ໄດ້ຮັບການຍອມຮັບ ເຊັ່ນ: ISO 9001, ISO 26000, ມາດຕ"
"ະຖານການຢັ້ງຢືນ AA1000,\n"
"                        ຫຼື ການກວດສອບຕາມກົດລະບຽບ."

#. module: esg_csrd
#: model_terms:knowledge.article,template_body:esg_csrd.esg_csrd_knowledge_article_template_csrd_appendix_governance_c
msgid ""
"Where relevant, governance indicators (e.g., confirmed corruption incidents, policy\n"
"                coverage, ethical training completion) undergo external assurance using recognized\n"
"                frameworks such as ISO 37001, AA1000 Assurance Standard, or national audit\n"
"                standards."
msgstr ""
"ໃນກໍລະນີທີ່ກ່ຽວຂ້ອງ, ຕົວຊີ້ວັດດ້ານທຳມາພິບານ (ເຊັ່ນ: ເຫດການສໍ້ລາດບັງຫຼວງທີ່ຖືກຢືນຢັນ, ການຄຸ້ມຄອງ\n"
"                ຂອງນະໂຍບາຍ, ການສຳເລັດການຝຶກອົບຮົມດ້ານຈັນຍາບັນ) ຈະຜ່ານການຢັ້ງຢືນຈາກພາຍນອ"
"ກ ໂດຍນຳໃຊ້ຂອບວຽກ\n"
"                ທີ່ໄດ້ຮັບການຍອມຮັບ ເຊັ່ນ: ISO 37001, ມາດຕະຖານການຢັ້ງຢືນ AA1000, ຫຼື ມາດຕະ"
"ຖານ\n"
"                ການກວດສອບແຫ່ງຊາດ."

#. module: esg_csrd
#: model_terms:knowledge.article,template_body:esg_csrd.esg_csrd_knowledge_article_template_csrd_iro_management
msgid ""
"Where relevant, references are included to external standards or\n"
"                        initiatives the company aligns with."
msgstr ""
"ໃນກໍລະນີທີ່ກ່ຽວຂ້ອງ, ຈະມີການລວມເອົາການອ້າງອີງເຖິງມາດຕະຖານພາຍນອກ ຫຼື\n"
"                        ໂຄງການລິເລີ່ມທີ່ບໍລິສັດປະຕິບັດຕາມ."

#. module: esg_csrd
#: model_terms:knowledge.article,template_body:esg_csrd.esg_csrd_knowledge_article_template_csrd_appendix_social_b
msgid ""
"Where relevant, workforce indicators (e.g., diversity, pay equity, safety)\n"
"                undergo external assurance in line with recognized frameworks such as <strong>ISAE\n"
"                3000</strong>, <strong>GRI 401-404</strong>, or <strong>ILO labor standards</strong>\n"
"                ."
msgstr ""
"ບ່ອນທີ່ກ່ຽວຂ້ອງ, ຕົວຊີ້ວັດກຳລັງແຮງງານ (ເຊັ່ນ: ຄວາມຫຼາກຫຼາຍ, ຄວາມສະເໝີພາບດ້ານຄ່າຈ້າງ, ຄວາມປອດໄພ)"
"\n"
"                ແມ່ນຜ່ານການຮັບປະກັນຈາກພາຍນອກ ໃຫ້ສອດຄ່ອງກັບຂອບວຽກທີ່ໄດ້ຮັບການຍອມຮັບ ເຊັ່ນ: "
"<strong>ISAE\n"
"                3000</strong>, <strong>GRI 401-404</strong>, ຫຼື <strong>ມາດຕະຖ"
"ານແຮງງານ ILO</strong>\n"
"                ."

#. module: esg_csrd
#: model_terms:knowledge.article,template_body:esg_csrd.esg_csrd_knowledge_article_template_csrd_basic_for_prepation
msgid ""
"Where reporting systems are still being harmonized, integration of\n"
"                        sustainability data collection, consolidation, and internal control\n"
"                        procedures is targeted for completion by <strong>[<em>insert target year</em>]</strong>."
msgstr ""
"ບ່ອນທີ່ລະບົບການລາຍງານຍັງຢູ່ໃນຂັ້ນຕອນການປັບປຸງໃຫ້ສອດຄ່ອງກັນ, ການເຊື່ອມໂຍງການເກັບກຳຂໍ້ມູນຄວາມຍືນຍົ"
"ງ,\n"
"                        ການຮວບຮວມ ແລະ ຂັ້ນຕອນການຄວບຄຸມພາຍໃນ\n"
"                        ແມ່ນມີເປົ້າໝາຍໃຫ້ສຳເລັດພາຍໃນປີ <strong>[<em>ໃສ່ປີເປົ້າໝາຍ</em>"
"]</strong>."

#. module: esg_csrd
#: model_terms:knowledge.article,template_body:esg_csrd.esg_csrd_knowledge_article_template_csrd_basic_for_prepation
msgid ""
"Where such topics have been assessed as <strong>material</strong>,\n"
"                                the entity should still provide a <strong>summary of relevant\n"
"                                impacts, policies,\n"
"                                    actions, and metrics</strong>."
msgstr ""
"ບ່ອນທີ່ຫົວຂໍ້ດັ່ງກ່າວໄດ້ຖືກປະເມີນວ່າເປັນ <strong>ສານະສຳຄັນ</strong>,\n"
"                                ອົງກອນຄວນສະໜອງ <strong>ບົດສະຫຼຸບກ່ຽວກັບຜົນກະທົບ, ນະໂຍ"
"ບາຍ,\n"
"                                ການດຳເນີນການ ແລະ ຕົວຊີ້ວັດທີ່ກ່ຽວຂ້ອງ</strong>."

#. module: esg_csrd
#: model_terms:knowledge.article,template_body:esg_csrd.esg_csrd_knowledge_article_template_csrd_basic_for_prepation
msgid "Which standards are partially or fully omitted"
msgstr "ມາດຕະຖານໃດທີ່ຖືກລະເວັ້ນບາງສ່ວນ ຫຼື ທັງໝົດ"

#. module: esg_csrd
#: model_terms:knowledge.article,template_body:esg_csrd.esg_csrd_knowledge_article_template_csrd_appendix_governance_c
msgid "Whistleblowing and grievance reporting platforms."
msgstr "ເວທີການແຈ້ງເບາະແສ ແລະ ການລາຍງານການຮ້ອງທຸກ."

#. module: esg_csrd
#: model_terms:knowledge.article,template_body:esg_csrd.esg_csrd_knowledge_article_template_csrd_esrs_s1
