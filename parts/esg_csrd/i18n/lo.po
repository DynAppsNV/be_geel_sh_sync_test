#. module: esg_csrd
#: model_terms:knowledge.article,template_body:esg_csrd.esg_csrd_knowledge_article_template_csrd_basic_for_prepation
msgid ""
"Include\n"
"                                all entities within the group structure. Indicate if some are\n"
"                                excluded due\n"
"                                to non-materiality or exemption and provide the rationale in\n"
"                                “Notes.”"
msgstr ""
"ລວມທັງ\n"
"                                ທຸກຫົວໜ່ວຍພາຍໃນໂຄງສ້າງກຸ່ມ. ລະບຸວ່າຫາກມີບາງຫົວໜ່ວຍ\n"
"                                ຖືກຍົກເວັ້ນເນື່ອງຈາກ\n"
"                                ຄວາມບໍ່ເປັນສາລະສຳຄັນ ຫຼື ການຍົກເວັ້ນ ແລະ ໃຫ້ເຫດຜົນໃນ\n"
"                                “ບັນທຶກ.”"

#. module: esg_csrd
#: model_terms:knowledge.article,template_body:esg_csrd.esg_csrd_knowledge_article_template_csrd_esrs_s1
msgid ""
"Include <strong>key categories only</strong>:\n"
"                                                                    employment type, gender, function, and\n"
"                                                                    geography"
msgstr ""
"ລວມເອົາ <strong>ສະເພາະໝວດໝູ່ທີ່ສຳຄັນ</strong>:\n"
"                                                                    ປະເພດການຈ້"
"າງງານ, ເພດ, ໜ້າທີ່, ແລະ\n"
"                                                                    ພູມສັນຖານ"

#. module: esg_csrd
#: model_terms:knowledge.article,template_body:esg_csrd.esg_csrd_knowledge_article_template_csrd_appendix_environmental_a
msgid ""
"Include <strong>verification status</strong> (internal/external,\n"
"                            partial/full)."
msgstr ""
"ລວມເອົາ <strong>ສະຖານະການຢືນຢັນ</strong> (ພາຍໃນ/ພາຍນອກ,\n"
"                            ບາງສ່ວນ/ທັງໝົດ)."

#. module: esg_csrd
#: model_terms:knowledge.article,template_body:esg_csrd.esg_csrd_knowledge_article_template_vsm_c3
msgid ""
"Include Scope 3 only for material categories and with sufficient data "
"quality."
msgstr ""
"ລວມເອົາ Scope 3 ສະເພາະໝວດໝູ່ທີ່ເປັນສາລະສຳຄັນ ແລະ ມີຄຸນນະພາບຂໍ້ມູນທີ່ພຽງພໍ."

#. module: esg_csrd
#: model_terms:knowledge.article,template_body:esg_csrd.esg_csrd_knowledge_article_template_csrd_esrs_e3
msgid ""
"Include actions targeting high-risk basins and specify the\n"
"                                        layer of the <strong>mitigation\n"
"                                            hierarchy</strong> (avoid/reduce/restore)."
msgstr ""
"ລວມເອົາການດຳເນີນການທີ່ແນໃສ່ແຫຼ່ງນ້ຳທີ່ມີຄວາມສ່ຽງສູງ ແລະ ລະບຸ\n"
"                                        ລະດັບຂອງ <strong>ລຳດັບການຫຼຸດຜ່ອນຜົນກະທົບ</"
"strong> (ຫຼີກເວັ້ນ/ຫຼຸດຜ່ອນ/ຟື້ນຟູ)."

#. module: esg_csrd
#: model_terms:knowledge.article,template_body:esg_csrd.esg_csrd_knowledge_article_template_vsm_b10
msgid ""
"Include additional guaranteed fixed payments that are part of the entry-"
"level wage."
msgstr ""
"ລວມເອົາການຈ່າຍເງິນຄົງທີ່ທີ່ໄດ້ຮັບການຮັບປະກັນເພີ່ມເຕີມ ເຊິ່ງເປັນສ່ວນໜຶ່ງຂອງຄ່າຈ້າງລະດັບເລີ່ມຕົ້ນ."

#. module: esg_csrd
#: model_terms:knowledge.article,template_body:esg_csrd.esg_csrd_knowledge_article_template_vsm_b11
msgid ""
"Include all fines, even if settled out of court, if imposed under applicable"
" anti-corruption laws. Clearly document calculation and reporting sources."
msgstr ""
"ລວມເອົາຄ່າປັບໄໝທັງໝົດ, ເຖິງແມ່ນວ່າຈະມີການຕົກລົງນອກສານ, ຫາກຖືກສັ່ງປັບພາຍໃຕ້ກົດໝາຍຕໍ່ຕ້ານການສໍ້ລາດບັງຫຼ"
"ວງ. ບັນທຶກການຄິດໄລ່ ແລະ ແຫຼ່ງລາຍງານຢ່າງຊັດເຈນ."

#. module: esg_csrd
#: model_terms:knowledge.article,template_body:esg_csrd.esg_csrd_knowledge_article_template_vsm_c9
msgid "Include all members, even if gender is “other” or “not declared.”"
msgstr "ລວມເອົາສະມາຊິກທັງໝົດ, ເຖິງແມ່ນວ່າເພດຈະເປັນ “ອື່ນໆ” ຫຼື “ບໍ່ໄດ້ລະບຸ.”"

#. module: esg_csrd
#: model_terms:knowledge.article,template_body:esg_csrd.esg_csrd_knowledge_article_template_vsm_c8
msgid ""
"Include all revenue sources even if below thresholds. Zero values should be "
"explicitly reported."
msgstr ""
"ລວມເອົາແຫຼ່ງລາຍຮັບທັງໝົດເຖິງແມ່ນວ່າຈະຕໍ່າກວ່າເກນກຳນົດ. ຄ່າທີ່ເປັນສູນຄວນຖືກລາຍງານຢ່າງຊັດເຈນ."

#. module: esg_csrd
#: model_terms:knowledge.article,template_body:esg_csrd.esg_csrd_knowledge_article_template_vsm_b9
msgid ""
"Include both ongoing and planned initiatives. Use concrete examples to "
"illustrate the type of actions, their coverage, and expected outcomes."
msgstr ""
"ລວມທັງຂໍ້ລິເລີ່ມທີ່ກຳລັງດຳເນີນການ ແລະ ທີ່ວາງແຜນໄວ້. ໃຊ້ຕົວຢ່າງທີ່ເປັນຮູບປະທຳເພື່ອສະແດງໃຫ້ເຫັນປະເພດການ"
"ດຳເນີນການ, ຂອບເຂດການຄຸ້ມຄອງ, ແລະ ຜົນໄດ້ຮັບທີ່ຄາດຫວັງ."

#. module: esg_csrd
#: model_terms:knowledge.article,template_body:esg_csrd.esg_csrd_knowledge_article_template_vsm_c4
msgid "Include both short-term (acute) and long-term (chronic) risks."
msgstr "ລວມທັງຄວາມສ່ຽງໄລຍະສັ້ນ (ຮຸນແຮງສຽບພັນ) ແລະ ໄລຍະຍາວ (ເຮື້ອຮັງ)."

#. module: esg_csrd
#: model_terms:knowledge.article,template_body:esg_csrd.esg_csrd_knowledge_article_template_vsm_c5
msgid "Include contractors working only for the company."
msgstr "ລວມເອົາຜູ້ຮັບເໝົາທີ່ເຮັດວຽກໃຫ້ກັບບໍລິສັດເທົ່ານັ້ນ."

#. module: esg_csrd
#: model_terms:knowledge.article,template_body:esg_csrd.esg_csrd_knowledge_article_template_csrd_esrs_g1
msgid ""
"Include financial and non-financial activities with\n"
"                                            context."
msgstr ""
"ລວມເອົາກິດຈະກຳທາງການເງິນ ແລະ ບໍ່ແມ່ນທາງການເງິນ\n"
"                                            ພ້ອມກັບບໍລິບົດ."

#. module: esg_csrd
#: model_terms:knowledge.article,template_body:esg_csrd.esg_csrd_knowledge_article_template_csrd_esrs_s1
msgid ""
"Include frequency rates, coverage, and severity\n"
"                                            indicators. Explain\n"
"                                            preventive actions or certifications (e.g., ISO 45001)."
msgstr ""
"ລວມເອົາອັດຕາຄວາມຖີ່, ຂອບເຂດການຄຸ້ມຄອງ, ແລະ ຕົວຊີ້ວັດ\n"
"                                            ຄວາມຮຸນແຮງ. ອະທິບາຍ\n"
"                                            ການດຳເນີນການປ້ອງກັນ ຫຼື ການຢືນຢັນ (ຕົວຢ່າ"
"ງ: ISO 45001)."

#. module: esg_csrd
#: model_terms:knowledge.article,template_body:esg_csrd.esg_csrd_knowledge_article_template_vsm_b1
msgid ""
"Include legal form, sector code, financial scale, workforce, and geolocation"
" of major sites."
msgstr ""
"ລວມເອົາຮູບແບບທາງກົດໝາຍ, ລະຫັດຂະແໜງການ, ຂະໜາດທາງການເງິນ, ແຮງງານ, ແລະ ທີ່ຕັ້ງທາງພູມສາດຂອງ"
"ສະຖານທີ່ຫຼັກ."

#. module: esg_csrd
#: model_terms:knowledge.article,template_body:esg_csrd.esg_csrd_knowledge_article_template_csrd_esrs_s4
msgid ""
"Include measurable, time-bound targets aligned with your\n"
"                                            supplier\n"
"                                            policies. State which indicators show improvement over\n"
"                                            time."
msgstr ""
"ລວມເອົາເປົ້າໝາຍທີ່ວັດແທກໄດ້ ແລະ ມີກຳນົດເວລາທີ່ສອດຄ່ອງກັບ\n"
"                                            ນະໂຍບາຍຜູ້ສະໜອງ\n"
"                                            ຂອງທ່ານ. ລະບຸວ່າຕົວຊີ້ວັດໃດທີ່ສະແດງໃຫ້ເຫັນເຖິ"
"ງການປັບປຸງ\n"
"                                            ຕາມໄລຍະເວລາ."

#. module: esg_csrd
#: model_terms:knowledge.article,template_body:esg_csrd.esg_csrd_knowledge_article_template_csrd_esrs_s2
msgid ""
"Include measurable, time-bound targets aligned with your\n"
"                                        supplier policies.\n"
"                                        State which indicators show improvement over time."
msgstr ""
"ລວມເອົາເປົ້າໝາຍທີ່ວັດແທກໄດ້ ແລະ ມີກຳນົດເວລາທີ່ສອດຄ່ອງກັບນະໂຍບາຍຜູ້ສະໜອງ.\n"
"                                        ລະບຸວ່າຕົວຊີ້ວັດໃດທີ່ສະແດງໃຫ້ເຫັນເຖິງການປັບປຸງຕາມໄ"
"ລຍະເວລາ."

#. module: esg_csrd
#: model_terms:knowledge.article,template_body:esg_csrd.esg_csrd_knowledge_article_template_csrd_esrs_s3
msgid ""
"Include measurable, time-bound targets. State which\n"
"                                                indicators show\n"
"                                                improvements over time."
msgstr ""
"ລວມເອົາເປົ້າໝາຍທີ່ວັດແທກໄດ້ ແລະ ມີກຳນົດເວລາ. ລະບຸວ່າ\n"
"                                                ຕົວຊີ້ວັດໃດທີ່ສະແດງໃຫ້ເຫັນ\n"
"                                                ເຖິງການປັບປຸງຕາມໄລຍະເວລາ."

#. module: esg_csrd
#: model_terms:knowledge.article,template_body:esg_csrd.esg_csrd_knowledge_article_template_vsm_b9
msgid ""
"Include mental health cases only if voluntarily disclosed and confirmed by a"
" licensed healthcare professional."
msgstr ""
"ລວມເອົາກໍລະນີສຸຂະພາບຈິດສະເພາະທີ່ມີການເປີດເຜີຍໂດຍສະໝັກໃຈ ແລະ ໄດ້ຮັບການຢືນຢັນຈາກຜູ້ຊ່ຽວຊານດ້ານສາທາ"
"ລະນະສຸກທີ່ມີໃບອະນຸຍາດ."

#. module: esg_csrd
#: model_terms:knowledge.article,template_body:esg_csrd.esg_csrd_knowledge_article_template_csrd_esrs_s1
msgid ""
"Include only <strong>material workforce\n"
"                                                        characteristics</strong> relevant to\n"
"                                                        impacts, risks, and opportunities."
msgstr ""
"ລວມເອົາສະເພາະ <strong>ຄຸນລັກສະນະຂອງກຳລັງແຮງງານ\n"
"                                                        ທີ່ເປັນສາລະສຳຄັນ</"
"strong> ທີ່ກ່ຽວຂ້ອງກັບ\n"
"                                                        ຜົນກະທົບ, ຄວາມສ່ຽງ, ແລະ "
"ໂອກາດ."

#. module: esg_csrd
#: model_terms:knowledge.article,template_body:esg_csrd.esg_csrd_knowledge_article_template_vsm_c5
msgid "Include only employees formally classified at management level."
msgstr "ລວມເອົາສະເພາະພະນັກງານທີ່ຖືກຈັດປະເພດຢູ່ໃນລະດັບການບໍລິຫານຢ່າງເປັນທາງການ."

#. module: esg_csrd
#: model_terms:knowledge.article,template_body:esg_csrd.esg_csrd_knowledge_article_template_vsm_c2
msgid ""
"Include only relevant practices, policies, and initiatives (no need for long"
" lists)."
msgstr ""
"ລວມເອົາສະເພາະການປະຕິບັດ, ນະໂຍບາຍ, ແລະ ຂໍ້ລິເລີ່ມທີ່ກ່ຽວຂ້ອງ (ບໍ່ຈຳເປັນຕ້ອງມີລາຍການຍາວໆ)."

#. module: esg_csrd
#: model_terms:knowledge.article,template_body:esg_csrd.esg_csrd_knowledge_article_template_vsm_c5
msgid "Include workers supplied by agencies."
msgstr "ລວມເອົາແຮງງານທີ່ສະໜອງໂດຍຕົວແທນ (agency)."

#. module: esg_csrd
#: model_terms:knowledge.article,template_body:esg_csrd.esg_csrd_knowledge_article_template_vsm_c5
msgid ""
"Include workers with material impact or significant numbers relative to the "
"workforce."
msgstr ""
"ລວມເອົາແຮງງານທີ່ມີຜົນກະທົບເປັນສາລະສຳຄັນ ຫຼື ມີຈຳນວນທີ່ສຳຄັນເມື່ອທຽບກັບກຳລັງແຮງງານທັງໝົດ."

#. module: esg_csrd
#: model_terms:knowledge.article,template_body:esg_csrd.esg_csrd_knowledge_article_template_csrd_appendix_environmental_a
msgid ""
"Includes 3-5 years of pollution data for key indicators with year-on-year trends and\n"
"                explanations for major variations."
msgstr ""
"ລວມເອົາຂໍ້ມູນມົນລະພິດ 3-5 ປີ ສຳລັບຕົວຊີ້ວັດຫຼັກ ພ້ອມກັບທ່າອ່ຽງໃນແຕ່ລະປີ ແລະ\n"
"                ຄຳອະທິບາຍສຳລັບການປ່ຽນແປງທີ່ສຳຄັນ."

#. module: esg_csrd
#: model_terms:knowledge.article,template_body:esg_csrd.esg_csrd_knowledge_article_template_csrd_appendix_environmental_a
msgid ""
"Includes 3-5 years of water consumption, discharge, and recycling trends, showing\n"
"                efficiency gains or impacts from climate variability and operational changes."
msgstr ""
"ລວມເອົາທ່າອ່ຽງການຊົມໃຊ້ນ້ຳ, ການປ່ອຍນ້ຳເສຍ, ແລະ ການນຳກັບມາໃຊ້ໃໝ່ 3-5 ປີ, ເຊິ່ງສະແດງໃຫ້ເຫັນ\n"
"                ເຖິງປະສິດທິພາບທີ່ເພີ່ມຂຶ້ນ ຫຼື ຜົນກະທົບຈາກຄວາມຜັນຜວນຂອງສະພາບອາກາດ ແລະ ການປ່ຽ"
"ນແປງການດຳເນີນງານ."

#. module: esg_csrd
#: model_terms:knowledge.article,template_body:esg_csrd.esg_csrd_knowledge_article_template_csrd_basic_for_prepation
msgid ""
"Includes <strong>downstream</strong> (customers, end users)\n"
"                                activities."
msgstr ""
"ລວມເອົາກິດຈະກຳ <strong>ປາຍນ້ຳ (downstream)</strong> (ລູກຄ້າ, ຜູ້ໃຊ້ສຸດທ້າຍ)."

#. module: esg_csrd
#: model_terms:knowledge.article,template_body:esg_csrd.esg_csrd_knowledge_article_template_csrd_basic_for_prepation
msgid "Includes <strong>upstream</strong> (suppliers, contractors),"
msgstr "ລວມເອົາ <strong>ຕົ້ນນ້ຳ (upstream)</strong> (ຜູ້ສະໜອງ, ຜູ້ຮັບເໝົາ),"

#. module: esg_csrd
#: model_terms:knowledge.article,template_body:esg_csrd.esg_csrd_knowledge_article_template_vsm_c9
msgid "Includes legally recognized third genders if applicable"
msgstr "ລວມເອົາເພດທີສາມທີ່ໄດ້ຮັບການຮັບຮອງທາງກົດໝາຍ ຫາກມີ"

#. module: esg_csrd
#: model_terms:knowledge.article,template_body:esg_csrd.esg_csrd_knowledge_article_template_vsm_b8
msgid "Includes permanent, temporary, and other contract types."
msgstr "ລວມເອົາພະນັກງານປະຈຳ, ຊົ່ວຄາວ, ແລະ ປະເພດສັນຍາອື່ນໆ."

#. module: esg_csrd
#: model_terms:knowledge.article,template_body:esg_csrd.esg_csrd_knowledge_article_template_vsm_b8
msgid ""
"Includes voluntary and involuntary departures, retirements, and deaths in "
"service."
msgstr ""
"ລວມເອົາການອອກວຽກໂດຍສະໝັກໃຈ ແລະ ບໍ່ສະໝັກໃຈ, ການອອກບຳນານ, ແລະ ການເສຍຊີວິດໃນລະຫວ່າງການປະ"
"ຕິບັດໜ້າທີ່."

#. module: esg_csrd
#: model_terms:knowledge.article,template_body:esg_csrd.esg_csrd_knowledge_article_template_csrd_basic_for_prepation
msgid "Incorporation by Reference"
msgstr "ການລວມເຂົ້າໂດຍການອ້າງອີງ"

#. module: esg_csrd
#: model_terms:knowledge.article,template_body:esg_csrd.esg_csrd_knowledge_article_template_vsm_appendix_b
msgid "Independent contractors in base year"
msgstr "ຜູ້ຮັບເໝົາອິດສະຫຼະໃນປີຖານ"

#. module: esg_csrd
#: model_terms:knowledge.article,template_body:esg_csrd.esg_csrd_knowledge_article_template_vsm_appendix_b
msgid "Independent contractors in the reporting year"
msgstr "ຜູ້ຮັບເໝົາອິດສະຫຼະໃນປີທີ່ລາຍງານ"

#. module: esg_csrd
#: model_terms:knowledge.article,template_body:esg_csrd.esg_csrd_knowledge_article_template_csrd_governance
msgid "Independent members (%)"
msgstr "ສະມາຊິກອິດສະຫຼະ (%)"

#. module: esg_csrd
#: model_terms:knowledge.article,template_body:esg_csrd.esg_csrd_knowledge_article_template_csrd_esrs_e3
msgid ""
"Indicate if targets consider <strong>local ecological\n"
"                                        thresholds</strong> or <strong>entity-specific\n"
"                                            allocations</strong>."
msgstr ""
"ລະບຸວ່າເປົ້າໝາຍໄດ້ພິຈາລະນາ <strong>ຂີດຈຳກັດທາງນິເວດວິທະຍາ\n"
"                                        ທ້ອງຖິ່ນ</strong> ຫຼື <strong>ການຈັດສັນສະເພາ"
"ະ\n"
"                                            ຂອງຫົວໜ່ວຍ</strong> ຫຼື ບໍ່."

#. module: esg_csrd
#: model_terms:knowledge.article,template_body:esg_csrd.esg_csrd_knowledge_article_template_csrd_appendix_environmental_a
msgid ""
"Indicate limitations and future improvement plans for emissions\n"
"                            tracking."
msgstr ""
"ລະບຸຂໍ້ຈຳກັດ ແລະ ແຜນການປັບປຸງໃນອະນາຄົດສຳລັບການຕິດຕາມ\n"
"                            ການປ່ອຍອາຍພິດ."

#. module: esg_csrd
#: model_terms:knowledge.article,template_body:esg_csrd.esg_csrd_knowledge_article_template_vsm_b2
msgid ""
"Indicate public availability if the policy or initiative is documented "
"internally or externally."
msgstr ""
"ລະບຸການເຂົ້າເຖິງສາທາລະນະ ຫາກນະໂຍບາຍ ຫຼື ຂໍ້ລິເລີ່ມຖືກບັນທຶກໄວ້ພາຍໃນ ຫຼື ພາຍນອກ."

#. module: esg_csrd
#: model_terms:knowledge.article,template_body:esg_csrd.esg_csrd_knowledge_article_template_csrd_strategy
msgid "Indicate the SDGs to which these objectives contribute."
msgstr "ລະບຸ SDGs ທີ່ຈຸດປະສົງເຫຼົ່ານີ້ມີສ່ວນຮ່ວມ."

#. module: esg_csrd
#: model_terms:knowledge.article,template_body:esg_csrd.esg_csrd_knowledge_article_template_csrd_appendix_social_b
msgid ""
"Indicate the level of assurance (internal review, partial or\n"
"                                    full external verification)."
msgstr ""
