#. module: esg_csrd
#: model_terms:knowledge.article,template_body:esg_csrd.esg_csrd_knowledge_article_template_csrd_esrs_e3
msgid "Water Consumption (E3-4) <span class=\"d-print-none\">[Material]</span>"
msgstr ""
"ການຊົມໃຊ້ນ້ຳ (E3-4) <span class=\"d-print-none\">[ທີ່ມີຄວາມສຳຄັນ]</span>"

#. module: esg_csrd
#: model_terms:knowledge.article,template_body:esg_csrd.esg_csrd_knowledge_article_template_csrd_esrs_e3
