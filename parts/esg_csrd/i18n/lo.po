#. module: esg_csrd
#: model_terms:knowledge.article,template_body:esg_csrd.esg_csrd_knowledge_article_template_vsm_c6
msgid "“0” is a valid required disclosure."
msgstr "“0” ແມ່ນການເປີດເຜີຍຂໍ້ມູນທີ່ຈຳເປັນ ແລະ ຖືກຕ້ອງ."

#. module: esg_csrd
#: model_terms:knowledge.article,template_body:esg_csrd.esg_csrd_knowledge_article_template_vsm_b8
msgid "“Not reported” includes employees who choose not to disclose gender."
msgstr "“ບໍ່ໄດ້ລາຍງານ” ລວມມີພະນັກງານທີ່ເລືອກບໍ່ເປີດເຜີຍເພດ."

#. module: esg_csrd
#: model_terms:knowledge.article,template_body:esg_csrd.esg_csrd_knowledge_article_template_csrd_appendix_placeholders
#: model_terms:knowledge.article,template_body:esg_csrd.esg_csrd_knowledge_article_template_vsm_appendix_b
msgid "“Other” gender employees in the base year"
msgstr "ພະນັກງານເພດ “ອື່ນໆ” ໃນປີພື້ນຖານ"

#. module: esg_csrd
#: model_terms:knowledge.article,template_body:esg_csrd.esg_csrd_knowledge_article_template_csrd_appendix_placeholders
#: model_terms:knowledge.article,template_body:esg_csrd.esg_csrd_knowledge_article_template_vsm_appendix_b
msgid "“Other” gender employees in the reporting year"
msgstr "ພະນັກງານເພດ “ອື່ນໆ” ໃນປີທີ່ລາຍງານ"

#. module: esg_csrd
#: model_terms:knowledge.article,template_body:esg_csrd.esg_csrd_knowledge_article_template_vsm_b8
msgid "“Other” includes legally recognized third genders where applicable."
msgstr "“ອື່ນໆ” ລວມມີເພດທີສາມທີ່ໄດ້ຮັບການຮັບຮອງທາງກົດໝາຍໃນບ່ອນທີ່ນຳໃຊ້ໄດ້."

#. module: esg_csrd
#: model_terms:knowledge.article,template_body:esg_csrd.esg_csrd_knowledge_article_template_vsm_c5
msgid ""
"“Other” includes legally recognized third genders; “Not reported” for "
"employees who chose not to disclose."
msgstr ""
"“ອື່ນໆ” ລວມມີເພດທີສາມທີ່ໄດ້ຮັບການຮັບຮອງທາງກົດໝາຍ; “ບໍ່ໄດ້ລາຍງານ” ສຳລັບພະນັກງານທີ່ເລືອກບໍ່ເປີດເຜີຍ."

#. module: esg_csrd
#: model_terms:knowledge.article,template_body:esg_csrd.esg_csrd_knowledge_article_template_vsm_b5
msgid ""
"“Sensitive areas” typically include Natura 2000, Ramsar sites, UNESCO "
"reserves, or equivalent national designations."
msgstr ""
"“ເຂດທີ່ອ່ອນໄຫວ” ໂດຍທົ່ວໄປແລ້ວລວມມີ Natura 2000, ສະຖານທີ່ Ramsar, ເຂດສະຫງວນຂອງ UNESCO, "
"ຫຼື ການກຳນົດລະດັບຊາດທີ່ທຽບເທົ່າ."
