#. module: esg_csrd
#: model_terms:knowledge.article,template_body:esg_csrd.esg_csrd_knowledge_article_template_vsm_b9
msgid "Distinguish between injuries and work-related ill health."
msgstr "ແຍກຄວາມແຕກຕ່າງລະຫວ່າງການບາດເຈັບ ແລະ ພະຍາດທີ່ເກີດຈາກການເຮັດວຽກ."

#. module: esg_csrd
#: model_terms:knowledge.article,template_body:esg_csrd.esg_csrd_knowledge_article_template_vsm_b10
msgid ""
"Distinguish collective bargaining coverage from union membership. Coverage "
"rates can be grouped in ranges (0-19%, 20-39%, etc.) if desired."
msgstr ""
"ແຍກຄວາມແຕກຕ່າງລະຫວ່າງການຄຸ້ມຄອງການເຈລະຈາຕໍ່ຮອງຮ່ວມ ແລະ ການເປັນສະມາຊິກສະຫະພັນ. ອັດຕາການຄຸ້ມ"
"ຄອງສາມາດຈັດກຸ່ມເປັນຊ່ວງ (0-19%, 20-39%, ແລະ ອື່ນໆ) ໄດ້ຕາມຕ້ອງການ."

#. module: esg_csrd
#: model_terms:knowledge.article,template_body:esg_csrd.esg_csrd_knowledge_article_template_csrd_esrs_s1
msgid "Diversity Metrics (S1-9)"
msgstr "ຕົວຊີ້ວັດຄວາມຫຼາກຫຼາຍ (S1-9)"

#. module: esg_csrd
#: model_terms:knowledge.article,template_body:esg_csrd.esg_csrd_knowledge_article_template_csrd_esrs_s1
msgid "Diversity Metrics (S1-9) <span class=\"d-print-none\">[Material]</span>"
msgstr ""
