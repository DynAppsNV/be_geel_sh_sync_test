#. module: equity
#: model:mail.template,body_html:equity.equity_shareholder_email_template
msgid ""
"<div>\n"
"                    <p> Hello <t t-out=\"ctx.get('holder_name')\"/>,<br/>\n"
"                        You will find your latest transaction and valuations in the following link: <br/>\n"
"                        <a t-attf-href=\"/my/equity?access_token={{ctx.get('equity_access_token')}}\" class=\"btn btn-primary\">Show Equity</a> <br/> <br/>\n"
"                        Best,\n"
"                        <t t-if=\"user_id.signature\">\n"
"                            <br/>--<br/>\n"
"                            <t t-out=\"user_id.signature or ''\">Mitchell Admin</t>\n"
"                        </t>\n"
"                    </p>\n"
"                </div>\n"
"            "
msgstr ""
"<div>\n"
"                    <p> ສະບາຍດີ <t t-out=\"ctx.get('holder_name')\"/>,<br/>\n"
"                        ທ່ານສາມາດກວດສອບລາຍການເຄື່ອນໄຫວ ແລະ ການປະເມີນມູນຄ່າຫຼ້າສຸດໄດ້ທີ່ລິ້ງ"
"ລຸ່ມນີ້: <br/>\n"
"                        <a t-attf-href=\"/my/equity?access_token={{ctx.get"
"('equity_access_token')}}\" class=\"btn btn-primary\">ເບິ່ງສ່ວນທຶນ</a> <br/> "
"<br/>\n"
"                        ດ້ວຍຄວາມນັບຖື,\n"
"                        <t t-if=\"user_id.signature\">\n"
"                            <br/>--<br/>\n"
"                            <t t-out=\"user_id.signature or ''\">Mitchell "
"Admin</t>\n"
"                        </t>\n"
"                    </p>\n"
"                </div>\n"
"            "

#. module: equity
#: model:mail.template,body_html:equity.equity_ubo_form_email_template
msgid ""
"<div>\n"
"                    <p> Hello <t t-out=\"object.name\"/>,<br/>\n"
"                        Following our legal obligations to identify clients, we need to report natural persons who directly or indirectly\n"
"                        hold or control at least 25% in the capital or voting rights of <b><t t-out=\"user_id.company_id.name\"/></b>. <br/> <br/>\n"
"                        Please fill in the UBO request:<br/>\n"
"                        <a t-attf-href=\"/my/ubo?{{object._get_equity_url_params()}}\" class=\"btn btn-primary\">Fill UBO</a> <br/> <br/>\n"
"                        Thank you,\n"
"                        <t t-if=\"user_id.signature\">\n"
"                            <br/>--<br/>\n"
"                            <t t-out=\"user_id.signature or ''\">Mitchell Admin</t>\n"
"                        </t>\n"
"                    </p>\n"
"                </div>\n"
"            "
msgstr ""
"<div>\n"
"                    <p> ສະບາຍດີ <t t-out=\"object.name\"/>,<br/>\n"
"                        ອີງຕາມພັນທະທາງກົດໝາຍໃນການລະບຸຕົວຕົນລູກຄ້າ, ພວກເຮົາຈຳເປັນຕ້ອງລາຍງ"
"ານບຸກຄົນທີ່ຖືຄອງ ຫຼື ຄວບຄຸມທຶນ\n"
"                        ຫຼື ສິດໃນການອອກສຽງຢ່າງໜ້ອຍ 25% ທັງທາງກົງ ຫຼື ທາງອ້ອມ ຂອງ <b><t "
"t-out=\"user_id.company_id.name\"/></b>. <br/> <br/>\n"
"                        ກະລຸນາຕື່ມຂໍ້ມູນ UBO:<br/>\n"
"                        <a t-attf-href=\"/my/ubo?{"
"{object._get_equity_url_params()}}\" class=\"btn btn-primary\">ຕື່ມຂໍ້ມູນ UBO</a> "
"<br/> <br/>\n"
"                        ຂອບໃຈ,\n"
"                        <t t-if=\"user_id.signature\">\n"
"                            <br/>--<br/>\n"
"                            <t t-out=\"user_id.signature or ''\">Mitchell "
"Admin</t>\n"
"                        </t>\n"
"                    </p>\n"
"                </div>\n"
"            "

