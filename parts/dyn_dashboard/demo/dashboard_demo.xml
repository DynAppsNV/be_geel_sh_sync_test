    <!--Linechart column-->
    <record id="xx_dashboard_tile_linechart-column" model="xx.dashboard.tile">
        <field name="sequence">203</field>
        <field name="name"># Partners linechart (column)</field>
        <field name="dashboard_id" ref="dyn_dashboard.xx_dashboard_demo" />
        <field name="display_type">line_chart</field>
        <field name="width">10</field>
        <field name="height">3</field>
        <field name="bg_color_header">#AAA</field>
        <field name="query">
            select to_char(date_trunc('MONTH',P.create_date::date),'YYYY-Mon') as PRD, S.name state
            , count(*) as aantal
            from res_partner P
            join res_country_state S on S.id = P.state_id
            group by to_char(date_trunc('MONTH',P.create_date::date),'YYYY-Mon'), S.name
            order by to_char(date_trunc('MONTH',P.create_date::date),'YYYY-Mon')
            limit 20;
        </field>
        <field name="direction" />
        <field name="is_stacked">True</field>
        <field name="show_labels">False</field>
        <field name="show_legend">True</field>
        <field name="show_markers">False</field>
    </record>
