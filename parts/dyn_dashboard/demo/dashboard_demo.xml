    <!--    KPI -->
    <record id="xx_dashboard_tile_demodrillkpi" model="xx.dashboard.tile">
        <field name="sequence">102</field>
        <field name="name">Total # Partners KPI</field>
        <field name="dashboard_id" ref="dyn_dashboard.xx_dashboard_drill" />
        <field name="display_type">kpi</field>
        <field name="width">4</field>
        <field name="height">1</field>
        <field name="bg_color_header">#AAA</field>
        <field name="query">
            WITH kpi_data as (
            select p.id
            from res_partner p join res_country_state s on p.state_id = s.id
            where is_company in ( _IS_COMPANY_ )
            and active in ( _IS_ACTIVE_ )
            and p.id in ( _PARTNER_IDS_ )
            and p.country_id in ( _COUNTRY_IDS_ )
            )
            select count(id)::text as kpi, coalesce(string_agg(id::text,',' order by id),'0') ids
            from kpi_data;
        </field>
        <field name="direction">horizontal</field>
        <field name="show_labels">True</field>
        <field name="show_legend">True</field>
        <field name="show_markers">True</field>
        <field name="drill_type">model</field>
        <field name="model_id" ref="base.model_res_partner" />
        <field name="new_tab" eval="True" />
    </record>

    <!--    Selected Dates Table -->
    <record id="xx_dashboard_tile_drilldatestable" model="xx.dashboard.tile">
        <field name="sequence">101</field>
        <field name="name">Selected Dates table</field>
        <field name="dashboard_id" ref="dyn_dashboard.xx_dashboard_drill" />
        <field name="display_type">table</field>
        <field name="width">16</field>
        <field name="height">2</field>
        <field name="bg_color_header">#AAA</field>
        <field name="query">
            select %TIMESTAMPSTART as STRTDT  ,%TIMESTAMPEND as ENDDT,
                %DATESTART as STRT  ,%DATEEND as ND,
                P.create_date, P.id, P.name
            from res_partner p
            left join res_country rc on rc.id = p.country_id
            where p.create_date between %TIMESTAMPSTART and %TIMESTAMPEND
            and p.name ilike '%_NAME_%'
            and p.country_id in ( _COUNTRY_IDS_ )
            order by p.id;

        </field>
        <field name="direction">horizontal</field>
        <field name="drill_type">model</field>
        <field name="model_id" ref="base.model_res_partner" />
    </record>

