<?xml version="1.0" encoding="utf-8" ?>
<odoo>
    <record id="res_partner_view_form" model="ir.ui.view">
        <field name="name">res.partner.view.form.inherit.credit_limit</field>
        <field name="model">res.partner</field>
        <field name="inherit_id" ref="base.view_partner_form" />
        <field name="arch" type="xml">
            <xpath expr="//div[hasclass('oe_button_box')]" position="inside">
                <button
                    name="action_open_credit_lines"
                    type="object"
                    string="View Credits"
                    class="oe_stat_button"
                    icon="fa-bars"
                >
                    <field name="xx_credit_line_count" widget="statinfo" />
                </button>
            </xpath>
            <page name="sales_purchases" position="after">
                <page string="Credit Limit">
                    <field name="xx_credit_line_ids">
                        <list string="Type" default_group_by="credit_line_type_id">
                            <field name="credit_line_type_id" />
                            <field name="date" />
                            <field name="expiration_date" />
                            <field name="name_insurance_company_id" />
                            <field name="amount" />
                        </list>
                    </field>
                </page>
            </page>
        </field>
    </record>
</odoo>
