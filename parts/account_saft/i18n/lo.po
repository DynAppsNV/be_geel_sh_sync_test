#. module: account_saft
#. odoo-python
#: code:addons/account_saft/models/account_general_ledger.py:0
msgid "Partners to be checked"
msgstr "ຄູ່ຄ້າທີ່ຕ້ອງໄດ້ຮັບການກວດສອບ"

#. module: account_saft
#. odoo-python
#: code:addons/account_saft/models/account_general_ledger.py:0
msgid "Please define one or more Contacts belonging to your company."
msgstr "ກະລຸນາກຳນົດຜູ້ຕິດຕໍ່ໜຶ່ງຄົນ ຫຼື ຫຼາຍກວ່ານັ້ນທີ່ຂຶ້ນກັບບໍລິສັດຂອງທ່ານ."

#. module: account_saft
#. odoo-javascript
#: code:addons/account_saft/static/src/components/general_ledger/filters/warnings.xml:0
msgid "Please define the following for"
msgstr "ກະລຸນາກຳນົດສິ່ງຕໍ່ໄປນີ້ສຳລັບ"

#. module: account_saft
#. odoo-python
#: code:addons/account_saft/models/account_general_ledger.py:0
msgid "SAF-T is only compatible with one column group."
msgstr "SAF-T ສາມາດໃຊ້ໄດ້ກັບກຸ່ມຖັນດຽວເທົ່ານັ້ນ."

#. module: account_saft
#. odoo-python
#: code:addons/account_saft/models/account_general_ledger.py:0
msgid "Some partners are missing at least one address (Zip/City)."
msgstr "ຄູ່ຄ້າບາງລາຍຂໍ້ມູນທີ່ຢູ່ບໍ່ຄົບຖ້ວນ (ລະຫັດໄປສະນີ/ເມືອງ)."

#. module: account_saft
#. odoo-python
#: code:addons/account_saft/models/account_general_ledger.py:0
msgid "Undistributed profits or losses may cause export rejection."
msgstr "ກຳໄລ ຫຼື ຂາດທຶນທີ່ບໍ່ທັນໄດ້ຈັດສັນອາດເຮັດໃຫ້ການສົ່ງອອກຂໍ້ມູນຖືກປະຕິເສດ."

#. module: account_saft
#. odoo-python
#: code:addons/account_saft/models/account_general_ledger.py:0
msgid "View Company Partner"
msgstr "ເບິ່ງຄູ່ຄ້າບໍລິສັດ"

#. module: account_saft
#. odoo-python
#: code:addons/account_saft/models/account_general_ledger.py:0
msgid "View Partners"
msgstr "ເບິ່ງຄູ່ຄ້າ"

#. module: account_saft
#. odoo-python
#: code:addons/account_saft/models/account_general_ledger.py:0
msgid "the Company ID"
msgstr "ລະຫັດບໍລິສັດ"

#. module: account_saft
#. odoo-python
#: code:addons/account_saft/models/account_general_ledger.py:0
msgid "the city or zip code"
msgstr "ເມືອງ ຫຼື ລະຫັດໄປສະນີ"

#. module: account_saft
#. odoo-python
#: code:addons/account_saft/models/account_general_ledger.py:0
msgid "the phone number"
msgstr "ເບີໂທລະສັບ"

#. module: account_saft
#. odoo-javascript
#: code:addons/account_saft/static/src/components/general_ledger/filters/warnings.xml:0
msgid "your company"
