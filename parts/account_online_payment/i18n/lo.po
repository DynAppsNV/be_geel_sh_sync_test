#. module: account_online_payment
#. odoo-python
#: code:addons/account_online_payment/models/account_batch_payment.py:0
msgid ""
"\n"
"                This payment requires a KYC flow. As this process can take a few days, please use SEPA XML export in the meantime.\n"
"                You will be notified once the KYC flow is completed and you can proceed with the online payment.\n"
"            "
msgstr ""
"\n"
"                ການຊຳລະເງິນນີ້ຕ້ອງມີຂະບວນການ KYC. ເນື່ອງຈາກຂະບວນການນີ້ອາດໃຊ້ເວລາສອງສາມ"
"ມື້, ກະລຸນາໃຊ້ການສົ່ງອອກ SEPA XML ໃນລະຫວ່າງນີ້.\n"
"                ທ່ານຈະໄດ້ຮັບການແຈ້ງເຕືອນເມື່ອຂະບວນການ KYC ສຳເລັດ ແລະ ທ່ານສາມາດດຳເນີນການ"
"ຊຳລະເງິນຜ່ານທາງອອນລາຍໄດ້.\n"
"            "

#. module: account_online_payment
#: model:mail.template,body_html:account_online_payment.mail_template_account_payment_activation
msgid ""
"<table border=\"0\" width=\"100%\" cellpadding=\"0\" bgcolor=\"#ededed\" style=\"padding: 20px; background-color: #ededed\" summary=\"o_mail_notification\">\n"
"                    <tbody>\n"
"                        <tr>\n"
"                            <td align=\"center\" style=\"min-width: 590px;\">\n"
"                                <table width=\"590\" border=\"0\" cellpadding=\"0\" bgcolor=\"#875A7B\" style=\"min-width: 590px; background-color: rgb(135,90,123); padding: 20px;\">\n"
"                                <tr>\n"
"                                    <td valign=\"middle\">\n"
"                                        <span style=\"font-size:20px; color:white; font-weight: bold;\">\n"
"                                            Unlock Seamless Payments in Odoo\n"
"                                        </span>\n"
"                                    </td>\n"
"                                    <td valign=\"middle\" align=\"right\">\n"
"                                        <img src=\"https://www.odoo.com/openerp_enterprise/static/img/mail/odoo_logo_white.png\" style=\"padding: 0px; margin: 0px; height: auto; width: 80px;\" alt=\"Odoo S.A.\"/>\n"
"                                    </td>\n"
"                                </tr>\n"
"                                </table>\n"
"                            </td>\n"
"                        </tr>\n"
"\n"
"                        <tr>\n"
"                            <td align=\"center\" style=\"min-width: 590px;\">\n"
"                                <table width=\"590\" border=\"0\" cellpadding=\"0\" bgcolor=\"#ffffff\" style=\"min-width: 590px; background-color: rgb(255, 255, 255); padding: 20px;\">\n"
"                                <tbody>\n"
"                                    <td valign=\"top\" style=\"font-family:Arial,Helvetica,sans-serif; color: #555; font-size: 14px;\">\n"
"                                        <p>Hi there,</p>\n"
"                                        <p>We see you haven't activated your payments feature in Odoo yet. By enabling it, you'll be able to process payments directly and efficiently through your Odoo account.</p>\n"
"                                        <p>Of course, if you've already activated payments since receiving this email, you can simply ignore this message.</p>\n"
"                                        <p>Ready to get started? Activate your payments here! You can also complete this setup later by visiting your scheduled activities within Odoo.</p>\n"
"\n"
"                                        <br/>\n"
"                                        <br/>\n"
"\n"
"                                        <center>\n"
"                                        <p>\n"
"                                            <a style=\"background-color: #1abc9c; padding: 20px; text-decoration: none; color: #fff; border-radius: 5px; font-size: 16px;\" t-att-href=\"ctx.get('url')\">\n"
"                                                Activate payments\n"
"                                            </a>\n"
"                                        </p>\n"
"\n"
"                                        <br/><br/><br/>\n"
"\n"
"                                        <p>\n"
"                                            Or copy/paste this link in your browser:<br/>\n"
"                                            <a t-att-href=\"ctx.get('url')\"><t t-out=\"ctx.get('url')\"/></a>\n"
"                                        </p>\n"
"                                        </center>\n"
"                                    </td>\n"
"                                </tbody>\n"
"                                </table>\n"
"                            </td>\n"
"                        </tr>\n"
"\n"
"                        <tr>\n"
"                            <td align=\"center\">\n"
"                                Powered by <a href=\"https://www.odoo.com\">Odoo</a>.\n"
"                            </td>\n"
"                        </tr>\n"
"                    </tbody>\n"
"                </table>\n"
"            "
msgstr ""
"<table border=\"0\" width=\"100%\" cellpadding=\"0\" bgcolor=\"#ededed\" "
"style=\"padding: 20px; background-color: #ededed\" "
"summary=\"o_mail_notification\">\n"
"                    <tbody>\n"
"                        <tr>\n"
"                            <td align=\"center\" style=\"min-width: 590px;\">"
"\n"
"                                <table width=\"590\" border=\"0\" "
"cellpadding=\"0\" bgcolor=\"#875A7B\" style=\"min-width: 590px; background-"
"color: rgb(135,90,123); padding: 20px;\">\n"
"                                <tr>\n"
"                                    <td valign=\"middle\">\n"
"                                        <span style=\"font-size:20px; "
"color:white; font-weight: bold;\">\n"
"                                            ປົດລັອກການຊຳລະເງິນທີ່ສະດວກສະບາຍໃນ "
"Odoo\n"
"                                        </span>\n"
"                                    </td>\n"
"                                    <td valign=\"middle\" align=\"right\">\n"
"                                        <img src=\"https://www.odoo.com/"
"openerp_enterprise/static/img/mail/odoo_logo_white.png\" style=\"padding: "
"0px; margin: 0px; height: auto; width: 80px;\" alt=\"Odoo S.A.\"/>\n"
"                                    </td>\n"
"                                </tr>\n"
"                                </table>\n"
"                            </td>\n"
"                        </tr>\n"
"\n"
"                        <tr>\n"
"                            <td align=\"center\" style=\"min-width: 590px;\">"
"\n"
"                                <table width=\"590\" border=\"0\" "
"cellpadding=\"0\" bgcolor=\"#ffffff\" style=\"min-width: 590px; background-"
"color: rgb(255, 255, 255); padding: 20px;\">\n"
"                                <tbody>\n"
"                                    <td valign=\"top\" style=\"font-"
"family:Arial,Helvetica,sans-serif; color: #555; font-size: 14px;\">\n"
"                                        <p>ສະບາຍດີ,</p>\n"
"                                        <p>ພວກເຮົາເຫັນວ່າທ່ານຍັງບໍ່ໄດ້ເປີດໃຊ້ງານຄຸນສົມບັດກ"
"ານຊຳລະເງິນໃນ Odoo ເທື່ອ. ໂດຍການເປີດໃຊ້ມັນ, ທ່ານຈະສາມາດດຳເນີນການຊຳລະເງິນໄດ້ໂດຍກົງ ແລະ ມີປະ"
"ສິດທິພາບຜ່ານບັນຊີ Odoo ຂອງທ່ານ.</p>\n"
"                                        <p>ແນ່ນອນ, ຖ້າທ່ານໄດ້ເປີດໃຊ້ການຊຳລະເງິນແລ້ວນັບ"
"ຕັ້ງແຕ່ໄດ້ຮັບອີເມວນີ້, ທ່ານສາມາດຂ້າມຂໍ້ຄວາມນີ້ໄດ້ເລີຍ.</p>\n"
"                                        <p>ພ້ອມທີ່ຈະເລີ່ມຕົ້ນແລ້ວບໍ? ເປີດໃຊ້ການຊຳລະເງິນຂອ"
"ງທ່ານທີ່ນີ້! ທ່ານຍັງສາມາດຕັ້ງຄ່ານີ້ໃຫ້ສຳເລັດໃນພາຍຫຼັງໄດ້ໂດຍການເຂົ້າໄປທີ່ກິດຈະກຳທີ່ກຳນົດໄວ້ຂອງທ່ານພາຍໃນ "
"Odoo.</p>\n"
"\n"
"                                        <br/>\n"
"                                        <br/>\n"
"\n"
"                                        <center>\n"
"                                        <p>\n"
"                                            <a style=\"background-color: "
"#1abc9c; padding: 20px; text-decoration: none; color: #fff; border-radius: "
"5px; font-size: 16px;\" t-att-href=\"ctx.get('url')\">\n"
"                                                ເປີດໃຊ້ການຊຳລະເງິນ\n"
"                                            </a>\n"
"                                        </p>\n"
"\n"
"                                        <br/><br/><br/>\n"
"\n"
"                                        <p>\n"
"                                            ຫຼື ສຳເນົາ/ວາງ ລິງກ໌ນີ້ໃນບຣາວເຊີຂອງທ່າ"
"ນ:<br/>\n"
"                                            <a t-att-href=\"ctx.get('url')\">"
"<t t-out=\"ctx.get('url')\"/></a>\n"
"                                        </p>\n"
"                                        </center>\n"
"                                    </td>\n"
"                                </tbody>\n"
"                                </table>\n"
"                            </td>\n"
"                        </tr>\n"
"\n"
"                        <tr>\n"
"                            <td align=\"center\">\n"
"                                ຂັບເຄື່ອນໂດຍ <a href=\"https://www.odoo.com\">"
"Odoo</a>.\n"
"                            </td>\n"
"                        </tr>\n"
"                    </tbody>\n"
"                </table>\n"
"            "

