#. module: account_reports
#: model:mail.template,body_html:account_reports.email_template_tax_return_deadline
msgid ""
"<div style=\"margin: 0px; padding: 0px;\">\n"
"                <p style=\"margin: 0px; padding: 0px;\">\n"
"                    Hi <span t-out=\"ctx.get('partner') and "
"ctx['partner'].name\"/>,<br/><br/>\n"
"                    The deadline to submit <strong t-out=\"object.name\"/> "
"is <strong t-out=\"object.date_deadline\"/>.<br/>\n"
"                    To avoid any potential fine, please ensure all remaining "
"documents are sent over as soon as possible.<br/>\n"
"                    If you've already submitted everything but still "
"received this email, it's likely the tax return hasn't been marked as "
"submitted in Odoo.<br/>\n"
"                    Should you have any question or need assistance, feel "
"free to get in touch.<br/><br/>\n"
"                    Best regards,<br/>\n"
"                </p>\n"
"            </div>\n"
"        "
msgstr ""
"<div style=\"margin: 0px; padding: 0px;\">\n"
"                <p style=\"margin: 0px; padding: 0px;\">\n"
"                    ສະບາຍດີ <span t-out=\"ctx.get('partner') and "
"ctx['partner'].name\"/>,<br/><br/>\n"
"                    ກຳນົດເວລາໃນການສົ່ງ <strong t-out=\"object.name\"/> ແມ່ນ "
"<strong t-out=\"object.date_deadline\"/>.<br/>\n"
"                    ເພື່ອຫຼີກລ່ຽງການປັບໄໝທີ່ອາດຈະເກີດຂຶ້ນ, "
"ກະລຸນາກວດສອບໃຫ້ແນ່ໃຈວ່າເອກະສານທີ່ເຫຼືອທັງໝົດໄດ້ຖືກສົ່ງມາໂດຍໄວທີ່ສຸດ.<br/>\n"
"                    ຫາກທ່ານໄດ້ສົ່ງທຸກຢ່າງແລ້ວແຕ່ຍັງໄດ້ຮັບອີເມວນີ້, "
"ອາດເປັນຍ້ອນວ່າການແຈ້ງອາກອນຍັງບໍ່ໄດ້ຖືກໝາຍວ່າສົ່ງແລ້ວໃນ Odoo.<br/>\n"
"                    ຫາກທ່ານມີຄຳຖາມ ຫຼື ຕ້ອງການຄວາມຊ່ວຍເຫຼືອ, ສາມາດຕິດຕໍ່ພວກເຮົາໄດ້ທຸກເວລາ."
"<br/><br/>\n"
"                    ດ້ວຍຄວາມນັບຖື,<br/>\n"
"                </p>\n"
"            </div>\n"
"        "

#. module: account_reports
#: model:mail.template,body_html:account_reports.email_template_generic_tax_instructions
msgid ""
"<div style=\"margin: 0px; padding: 0px;\">\n"
"                <p>\n"
"                    Dear <t t-out=\"object.company_id.name\">YourCompany</"
"t>,\n"
"                </p>\n"
"                <p>\n"
"                    Based on the documents and information received, the VAT "
"return of <t t-out=\"object.company_id.name\">YourCompany</t>\n"
"                    for period <t t-"
"out=\"object.type_id._get_period_name(object.company_id, object.date_from, "
"object.date_to)\"/> has been submitted.\n"
"                </p>\n"
"                <p>\n"
"                    It has been determined that an amount of <t t-"
"out=\"format_amount(object.total_amount_to_pay, "
"object.amount_to_pay_currency_id)\"/> remains payable.\n"
"                </p>\n"
"                <table style=\"border:1px solid black; padding:20px; text-"
"align:left; border-spacing: 16px;\">\n"
"                    <tr>\n"
"                        <td>Amount to Pay</td>\n"
"                        <td><t t-"
"out=\"format_amount(object.total_amount_to_pay, "
"object.amount_to_pay_currency_id)\"/></td>\n"
"                    </tr>\n"
"                    <tr>\n"
"                        <td>Due By</td>\n"
"                        <td><t t-out=\"format_date(object.date_deadline)\"/"
"></td>\n"
"                    </tr>\n"
"                </table>\n"
"                <p>Kind regards,</p>\n"
"                <p><t t-out=\"user.name\">Mitchell Admin</t></p>\n"
"            </div>\n"
"        "
msgstr ""
"<div style=\"margin: 0px; padding: 0px;\">\n"
"                <p>\n"
"                    ຮຽນ <t t-out=\"object.company_id.name\">YourCompany</"
"t>,\n"
"                </p>\n"
"                <p>\n"
"                    ອີງຕາມເອກະສານ ແລະ ຂໍ້ມູນທີ່ໄດ້ຮັບ, ການແຈ້ງອາກອນມູນຄ່າເພີ່ມຂອງ <t t-"
"out=\"object.company_id.name\">YourCompany</t>\n"
"                    ສຳລັບງວດ <t t-"
"out=\"object.type_id._get_period_name(object.company_id, object.date_from, "
"object.date_to)\"/> ໄດ້ຖືກສົ່ງແລ້ວ.\n"
"                </p>\n"
"                <p>\n"
"                    ມີຍອດເງິນທີ່ຕ້ອງຊຳລະຈຳນວນ <t t-"
"out=\"format_amount(object.total_amount_to_pay, "
"object.amount_to_pay_currency_id)\"/>.\n"
"                </p>\n"
"                <table style=\"border:1px solid black; padding:20px; text-"
"align:left; border-spacing: 16px;\">\n"
"                    <tr>\n"
"                        <td>ຈຳນວນເງິນທີ່ຕ້ອງຊຳລະ</td>\n"
"                        <td><t t-"
"out=\"format_amount(object.total_amount_to_pay, "
"object.amount_to_pay_currency_id)\"/></td>\n"
"                    </tr>\n"
"                    <tr>\n"
"                        <td>ກຳນົດຊຳລະພາຍໃນວັນທີ</td>\n"
"                        <td><t t-out=\"format_date(object.date_deadline)\"/"
"></td>\n"
"                    </tr>\n"
"                </table>\n"
"                <p>ດ້ວຍຄວາມນັບຖື,</p>\n"
"                <p><t t-out=\"user.name\">Mitchell Admin</t></p>\n"
"            </div>\n"
"        "

