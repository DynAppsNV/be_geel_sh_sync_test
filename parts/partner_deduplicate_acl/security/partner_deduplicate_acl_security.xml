<odoo>
    <!-- New user group category -->
    <record id="res_groups_privilege_deduplicate_contacts" model="res.groups.privilege">
        <field name="name">Deduplicate Contacts</field>
        <field name="category_id" ref="base.module_category_master_data" />
    </record>
    <!-- New user groups -->
    <record id="group_manually" model="res.groups">
        <field name="name">Manually</field>
        <field name="privilege_id" ref="res_groups_privilege_deduplicate_contacts" />
    </record>
    <record id="group_automatically" model="res.groups">
        <field name="name">Automatically</field>
        <field name="privilege_id" ref="res_groups_privilege_deduplicate_contacts" />
        <field name="implied_ids" eval="[Command.link(ref('group_manually'))]" />
    </record>
    <record id="group_unrestricted" model="res.groups">
        <field name="name">Without restrictions</field>
        <field name="privilege_id" ref="res_groups_privilege_deduplicate_contacts" />
        <field name="implied_ids" eval="[Command.link(ref('group_automatically'))]" />
    </record>
</odoo>
